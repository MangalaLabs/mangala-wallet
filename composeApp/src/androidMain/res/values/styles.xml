<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="android:Theme.Material.NoActionBar"/>

    <style name="NightAdjusted.Theme.Mangala" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Allows us to override platform level specific attributes in their
         respective values-vXX folder. -->
    <style name="PlatformAdjusted.Theme.Mangala" parent="NightAdjusted.Theme.Mangala">
        <item name="android:statusBarColor">@android:color/white</item>
    </style>

    <!-- The final theme we use -->
    <style name="Theme.Mangala" parent="PlatformAdjusted.Theme.Mangala">
<!--        <item name="android:background">@android:color/white</item>-->
    </style>

    <style name="NightAdjusted.Theme.Splash" parent="Theme.SplashScreen">
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.Mangala.Splash" parent="NightAdjusted.Theme.Splash">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Mangala</item>
    </style>
</resources>