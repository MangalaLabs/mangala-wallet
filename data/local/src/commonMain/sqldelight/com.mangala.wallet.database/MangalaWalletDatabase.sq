import com.mangala.wallet.local.cache.MetadataTargetCacheEntity;

CREATE TABLE IF NOT EXISTS PersonEntity (
    name TEXT,
    height TEXT,
    mass TEXT,
    url TEXT
);

insertPerson:
INSERT INTO PersonEntity(name, height, mass, url)
VALUES(?, ?, ?, ?);

removeAllPerson:
DELETE FROM PersonEntity;

selectAllPersonsInfo:
SELECT PersonEntity.*
FROM PersonEntity;

-- TABLE WALLET

CREATE TABLE IF NOT EXISTS WalletEntity (
  id TEXT PRIMARY KEY,
  name TEXT,
  words TEXT, -- Store encrypted version here
  passphrase TEXT, -- Store encrypted version here
  key TEXT, -- Not sure what this does? Maybe for multichain support?
  is_backed_up INTEGER,
  is_selected INTEGER
);

-- Wallet queries and operations
getAllWallets:
SELECT * FROM WalletEntity;

selectWalletById:
SELECT * FROM WalletEntity WHERE id = ?;

clearSelectedWallet:
UPDATE WalletEntity SET is_selected = 0;

setSelectedWallet:
UPDATE WalletEntity SET is_selected = 1 WHERE id = ?;

getSelectedWallet:
SELECT * FROM WalletEntity WHERE is_selected = 1 LIMIT 1;

insertWallet:
INSERT INTO WalletEntity (id, name, words, passphrase, key, is_backed_up, is_selected) VALUES (?, ?, ?, ?, ?, ?, ?);

updateWallet:
UPDATE WalletEntity SET name = ?, words = ?, passphrase = ?, key = ?, is_backed_up = ? WHERE id = ?;

deleteWallet:
DELETE FROM WalletEntity WHERE id = ?;

deleteAllWallets:
DELETE FROM WalletEntity;

updateWalletName:
UPDATE WalletEntity SET name = ? WHERE id = ?;

getWalletById:
SELECT * FROM WalletEntity WHERE id = ?;


-- TABLE ACCOUNT
CREATE TABLE IF NOT EXISTS AccountEntity (
  id TEXT PRIMARY KEY,
  name TEXT NOT NULL,
  type TEXT NOT NULL,
  wallet_id TEXT NOT NULL,
  derivation_path_index INTEGER NOT NULL,
  sorting_order INTEGER NOT NULL DEFAULT 0,
  is_hidden INTEGER NOT NULL DEFAULT 0,
  bip_44_address TEXT NOT NULL,
  bip_49_address TEXT NOT NULL,
  bip_84_address TEXT NOT NULL,
  FOREIGN KEY(wallet_id) REFERENCES WalletEntity(id) ON DELETE CASCADE
);

selectAccountById:
SELECT * FROM AccountEntity WHERE id = ?;

insertAccount:
INSERT INTO AccountEntity(id, name, type, wallet_id, derivation_path_index, sorting_order, bip_44_address, bip_49_address, bip_84_address)
VALUES(?, ?, ?, ?, ?, ?, ?, ?, ?);

removeAllAccounts:
DELETE FROM AccountEntity;

selectAllAccountsByWalletId:
SELECT * FROM AccountEntity WHERE wallet_id = ? ORDER BY sorting_order ASC;

selectAllActiveAccountsByWalletId:
SELECT * FROM AccountEntity WHERE wallet_id = ? AND is_hidden = 0 ORDER BY sorting_order ASC;

updateAccount:
UPDATE AccountEntity SET name = ?, sorting_order = ?, is_hidden = ? WHERE id = ?;

deleteAccount:
DELETE FROM AccountEntity WHERE id = ?;

updateHiddenAccount:
UPDATE AccountEntity
SET is_hidden = CASE WHEN is_hidden = 1 THEN 0 ELSE 1 END
WHERE id = ?;



-- TABLE BLOCKCHAIN ENTITY
CREATE TABLE IF NOT EXISTS BlockchainEntity (
    uid TEXT PRIMARY KEY,
    name TEXT,
    eip3091url TEXT
);

insertBlockchain:
INSERT INTO BlockchainEntity(uid, name, eip3091url)
VALUES(?, ?, ?);

CREATE INDEX IF NOT EXISTS index_blockchain_entity_uid ON BlockchainEntity(uid);


deleteAllBlockchain:
DELETE FROM BlockchainEntity;

deleteBlockchainById:
DELETE FROM BlockchainEntity WHERE uid = :uid;

getAllBlockchainEntity:
SELECT BlockchainEntity.*
FROM BlockchainEntity;

getBlockchainById: SELECT * FROM BlockchainEntity WHERE uid = :uid;

countBlockchain: SELECT COUNT(uid) FROM BlockchainEntity;

-- TABLE COIN
CREATE TABLE IF NOT EXISTS Coin (
    uid TEXT PRIMARY KEY,
    name TEXT NOT NULL,
    code TEXT NOT NULL,
    marketCapRank INTEGER,
    coinGeckoId TEXT
);

CREATE INDEX IF NOT EXISTS index_coin_uid ON Coin(uid);

insertCoin:
INSERT INTO Coin (uid, name, code, marketCapRank, coinGeckoId)
VALUES (?, ?, ?, ?, ?);

insertOrReplaceCoin:
INSERT OR REPLACE INTO Coin (uid, name, code, marketCapRank, coinGeckoId)
VALUES (?, ?, ?, ?, ?);

deleteCoinById:
DELETE FROM Coin WHERE uid = ?;

deleteAllCoin:
DELETE FROM Coin;

getCoinById:
SELECT * FROM Coin WHERE uid = ?;

getCoinByCode:
SELECT * FROM Coin WHERE code = ?;

getAllCoin:
SELECT * FROM Coin;

countCoin: SELECT COUNT(uid)  FROM Coin;

-- TABLE TOKEN ENTITY
CREATE TABLE IF NOT EXISTS TokenEntity (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    coin_uid TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    type TEXT NOT NULL,
    decimals INTEGER,
    reference TEXT,
    FOREIGN KEY (coin_uid) REFERENCES Coin (uid),
    FOREIGN KEY (blockchain_uid) REFERENCES BlockchainEntity (uid)
);

CREATE INDEX IF NOT EXISTS index_token_entity_coin_uid ON TokenEntity(coin_uid);

insertToken:
INSERT INTO TokenEntity (coin_uid, blockchain_uid, type, decimals, reference)
VALUES (?, ?, ?, ?, ?);

insertOrReplaceToken:
INSERT OR REPLACE INTO TokenEntity (coin_uid, blockchain_uid, type, decimals, reference)
VALUES (?, ?, ?, ?, ?);

getLastInsertedTokenRowId:
SELECT last_insert_rowid();

deleteTokenById:
DELETE FROM TokenEntity WHERE id = ?;

getTokenById:
SELECT * FROM TokenEntity WHERE id = ?;

getNativeCoin:
SELECT * FROM TokenEntity WHERE blockchain_uid = ? AND type = 'native' LIMIT 1;

getTokenByCoinUidAndBlockchainUid:
SELECT * FROM TokenEntity WHERE coin_uid = ? AND blockchain_uid = ?;

getFirst2TokenByBlockchainUid:
SELECT * FROM TokenEntity WHERE blockchain_uid = :blockchain_uid LIMIT 2;

countTokenByBlockchainUid:
SELECT COUNT(*) FROM TokenEntity WHERE blockchain_uid = :blockchain_uid;

getTokenByBlockchainUidPaged:
SELECT * FROM TokenEntity WHERE blockchain_uid = :blockchain_uid
LIMIT :limit OFFSET :offset;

getTokenByCoinUid:
SELECT * FROM TokenEntity WHERE coin_uid = ?;

getTokenByReference:
SELECT * FROM TokenEntity WHERE reference = ?;

getTokenByReferenceAndBlockchainUid:
SELECT * FROM TokenEntity WHERE reference = ? AND blockchain_uid = ?;

getTokenByReferences:
SELECT * FROM TokenEntity WHERE reference IN ?;

countToken: SELECT COUNT(id)  FROM TokenEntity;

-- TABLE TOKEN BALANCE ENTITY

CREATE TABLE IF NOT EXISTS TokenBalanceEntity (
  token_id INTEGER NOT NULL,
  account_id TEXT NOT NULL,
  blockchain_uid TEXT NOT NULL,
  balance TEXT NOT NULL,
  balance_24h TEXT ,
  balance_locked TEXT NOT NULL,
  order_number INTEGER NOT NULL,
  contract_decimals INTEGER NOT NULL,
  contract_name TEXT NOT NULL,
  contract_symbol TEXT NOT NULL,
  contract_address TEXT NOT NULL,
  logo_url TEXT,
  last_updated INTEGER,
  FOREIGN KEY (token_id) REFERENCES TokenEntity(id),
  FOREIGN KEY (account_id) REFERENCES AccountEntity(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS index_token_balance_token_id ON TokenBalanceEntity(token_id);

insertTokenBalance:
INSERT INTO TokenBalanceEntity (
  token_id,
  account_id,
  blockchain_uid,
  balance,
  balance_24h,
  balance_locked,
  order_number,
  contract_decimals,
  contract_name,
  contract_symbol,
  contract_address,
  logo_url,
  last_updated
) VALUES (?, ?,?, ?, ?, ?, ?, ?, ?, ?, ?, ?,?);

deleteTokenBalanceByTokenIdAndAccountId:
DELETE FROM TokenBalanceEntity WHERE token_id = ? AND account_id = ?;

deleteTokenBalanceByAccountId:
DELETE FROM TokenBalanceEntity WHERE account_id = ?;

deleteTokenBalanceByAccountIdAndBlockchainUid:
DELETE FROM TokenBalanceEntity WHERE account_id = ? AND blockchain_uid = ?;

getTokenBalanceByTokenIdAndAccountId:
SELECT * FROM TokenBalanceEntity WHERE token_id = ? AND account_id = ?;

getTokenBalanceByAccountIdAndBlockchainUid:
SELECT * FROM TokenBalanceEntity WHERE account_id = ? AND blockchain_uid = ?;

getTokenBalanceByAccountId:
SELECT * FROM TokenBalanceEntity WHERE account_id = ?;

updateTokenBalanceByTokenIdAndAccountId:
UPDATE TokenBalanceEntity SET blockchain_uid =?, balance = ?, balance_24h = ?, balance_locked = ?, order_number = ?, contract_decimals = ?, contract_name = ?, contract_symbol = ?, contract_address = ?, logo_url = ? WHERE token_id = ? AND account_id = ?;

insertOrReplaceTokenBalance:
INSERT OR IGNORE INTO TokenBalanceEntity (
  token_id,
  account_id,
  blockchain_uid,
  balance,
  balance_24h,
  balance_locked,
  order_number,
  contract_decimals,
  contract_name,
  contract_symbol,
  contract_address,
  logo_url,
  last_updated
)
VALUES (?, ?,?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- TABLE TOKEN PRICE ENTITY
-- create table
CREATE TABLE IF NOT EXISTS TokenPriceEntity (
  coin_uid TEXT NOT NULL,
  currency_code TEXT NOT NULL,
  current_price TEXT,
  market_cap TEXT,
  market_cap_rank INTEGER,
  total_volume TEXT,
  high_24h TEXT,
  low_24h TEXT,
  price_change_24h TEXT,
  price_change_percentage_24h TEXT,
  market_cap_change_24h TEXT,
  market_cap_change_percentage_24h TEXT,
  fully_diluted_valuation TEXT,
  circulating_supply TEXT,
  total_supply TEXT,
  max_supply TEXT,
  ath TEXT,
  ath_change_percentage TEXT,
  ath_date TEXT,
  atl TEXT,
  price_change_percentage_1h_in_currency TEXT,
  price_change_percentage_24h_in_currency TEXT,
  price_change_percentage_7d_in_currency TEXT,
  last_updated INTEGER,
  PRIMARY KEY (coin_uid)
);

-- insert
insertTokenPriceEntity:
INSERT INTO TokenPriceEntity (
  coin_uid, currency_code, current_price, market_cap, market_cap_rank, total_volume,
  high_24h, low_24h, price_change_24h, price_change_percentage_24h, market_cap_change_24h,
  market_cap_change_percentage_24h, fully_diluted_valuation, circulating_supply, total_supply,
  max_supply, ath, ath_change_percentage, ath_date, atl, price_change_percentage_1h_in_currency,
  price_change_percentage_24h_in_currency, price_change_percentage_7d_in_currency, last_updated
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- delete by coin_uid
deleteTokenPriceByCoinUid:
DELETE FROM TokenPriceEntity WHERE coin_uid = ?;

-- get by coin_uid
getTokenPriceByCoinUid:
SELECT * FROM TokenPriceEntity WHERE coin_uid = ?;

getTokenPriceByCoinUidAndCurrencyCode:
SELECT * FROM TokenPriceEntity WHERE coin_uid = ? AND currency_code = ?;

getTokenPriceByCoinUidsAndCurrencyCode:
SELECT * FROM TokenPriceEntity WHERE coin_uid IN ? AND currency_code = ?;

getTokenWithSparklineByCoinUidsAndCurrencyCode:
SELECT * FROM TokenPriceEntity
JOIN TokenPriceSparklineEntity ON TokenPriceEntity.coin_uid = TokenPriceSparklineEntity.coin_uid
WHERE TokenPriceEntity.coin_uid IN ? AND TokenPriceEntity.currency_code = ?;

-- update by coin_uid and currency_code
updateTokenPriceByCoinUidAndCurrencyCode:
UPDATE TokenPriceEntity SET
  current_price = ?, market_cap = ?, market_cap_rank = ?, total_volume = ?, high_24h = ?,
  low_24h = ?, price_change_24h = ?, price_change_percentage_24h = ?, market_cap_change_24h = ?,
  market_cap_change_percentage_24h = ?, fully_diluted_valuation = ?, circulating_supply = ?,
  total_supply = ?, max_supply = ?, ath = ?, ath_change_percentage = ?, ath_date = ?, atl = ?,
  price_change_percentage_1h_in_currency = ?, price_change_percentage_24h_in_currency = ?,
  price_change_percentage_7d_in_currency = ?, last_updated = ?
WHERE coin_uid = ? AND currency_code = ?;

insertOrReplaceTokenPriceEntity:
INSERT OR REPLACE INTO TokenPriceEntity (
  coin_uid, currency_code, current_price, market_cap, market_cap_rank, total_volume,
  high_24h, low_24h, price_change_24h, price_change_percentage_24h, market_cap_change_24h,
  market_cap_change_percentage_24h, fully_diluted_valuation, circulating_supply, total_supply,
  max_supply, ath, ath_change_percentage, ath_date, atl, price_change_percentage_1h_in_currency,
  price_change_percentage_24h_in_currency, price_change_percentage_7d_in_currency, last_updated
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

CREATE TABLE IF NOT EXISTS TokenExchangeRateEntity(
    coin_uid TEXT NOT NULL,
    quote_currency TEXT NOT NULL,
    rate TEXT NOT NULL,
    updated_at INTEGER NOT NULL,
    PRIMARY KEY (coin_uid, quote_currency)
);

insertOrReplaceTokenExchangeRate:
INSERT OR REPLACE INTO TokenExchangeRateEntity(coin_uid, quote_currency, rate, updated_at)
VALUES (?, ?, ?, ?);

selectAllTokenExchangeRateByCoinUid:
SELECT *
FROM TokenExchangeRateEntity
WHERE coin_uid = ?;

deleteTokenExchangeRateDataByCoinUid:
DELETE FROM TokenExchangeRateEntity
WHERE coin_uid = ?;

CREATE TABLE IF NOT EXISTS TokenExchangeRateMetadataEntity(
    coin_uid TEXT PRIMARY KEY,
    updated_at INTEGER NOT NULL
);

insertOrReplaceTokenExchangeRateMetadata:
INSERT OR REPLACE INTO TokenExchangeRateMetadataEntity(coin_uid, updated_at)
VALUES (?, ?);

getTokenExchangeRateMetadataByCoinUid:
SELECT updated_at
FROM TokenExchangeRateMetadataEntity
WHERE coin_uid = ?;

deleteTokenExchangeRateMetadataByCoinUid:
DELETE FROM TokenExchangeRateMetadataEntity
WHERE coin_uid = ?;

-- TABLE TOKEN PRICE SPARKLINE ENTITY
-- create table
CREATE TABLE IF NOT EXISTS TokenPriceSparklineEntity (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  coin_uid TEXT NOT NULL,
  timestamp INTEGER NOT NULL,
  price REAL,
  FOREIGN KEY(coin_uid) REFERENCES TokenPriceEntity(coin_uid) ON DELETE CASCADE
);

insertOrReplaceTokenPriceSparklineEntity:
INSERT OR REPLACE INTO TokenPriceSparklineEntity(coin_uid, timestamp, price)
VALUES (?, ?, ?);

deleteTokenPriceSparklineByCoinUid:
DELETE FROM TokenPriceSparklineEntity WHERE coin_uid = ?;

-- TABLE CONTACT

CREATE TABLE IF NOT EXISTS ContactEntity (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT,
  blockchain_uid TEXT,
  address TEXT
);

-- Wallet queries and operations
getAllContacts:
SELECT * FROM ContactEntity;

getAllContactsByBlockchainUid:
SELECT *
FROM ContactEntity
WHERE (:blockchainUid IS NULL OR blockchain_uid = :blockchainUid)
ORDER BY name ASC;

selectContactById:
SELECT * FROM ContactEntity WHERE id = ?;

insertContact:
INSERT INTO ContactEntity (name, blockchain_uid, address) VALUES (?, ?, ?);

updateContact:
UPDATE ContactEntity SET name = ?, blockchain_uid = ?, address = ? WHERE id = ?;

deleteContact:
DELETE FROM ContactEntity WHERE id = ?;

lastInsertedRowId:
SELECT last_insert_rowid();

