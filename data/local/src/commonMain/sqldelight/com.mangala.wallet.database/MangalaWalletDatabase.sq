-- TABLE TRANSACTION ENTITY

CREATE TABLE IF NOT EXISTS TransactionsEntity (
    blockHeight INTEGER NOT NULL,
    blockSignedAt INTEGER NOT NULL,
    feesPaid TEXT NOT NULL,
    fromAddress TEXT NOT NULL,
    fromAddressLabel TEXT NOT NULL,
    gasContractAddress TEXT,
    gasContractDecimals INTEGER,
    gasContractName TEXT,
    gasContractTickerSymbol TEXT,
    gasLogoUrl TEXT,
    gasOffered INTEGER NOT NULL,
    gasPrice TEXT NOT NULL,
    gasQuote TEXT NOT NULL,
    gasQuoteRate TEXT NOT NULL,
    gasSpent TEXT NOT NULL,
    minerAddress TEXT NOT NULL,
    prettyGasQuote TEXT NOT NULL,
    prettyValueQuote TEXT NOT NULL,
    status TEXT NOT NULL,
    toAddress TEXT NOT NULL,
    toAddressLabel TEXT NOT NULL,
    transactionHash TEXT PRIMARY KEY,
    txOffset INTEGER NOT NULL,
    value TEXT NOT NULL,
    valueQuote TEXT NOT NULL,
    accountId TEXT NOT NULL,
    transactionType TEXT NOT NULL,
    logEvents TEXT,
    blockchain_uid TEXT NOT NULL,
    is_nft_transaction INTEGER NOT NULL DEFAULT 0,
    nft_transfers TEXT,
    erc20_transfers TEXT,
    native_transfers TEXT,
    FOREIGN KEY(accountId) REFERENCES AccountEntity(id) ON DELETE CASCADE
);

countTransactions:
SELECT COUNT(*)
FROM TransactionsEntity
WHERE accountId = :accountId
AND blockchain_uid = :blockchainUid
AND (transactionType = :transactionType OR :transactionType IS NULL)
AND (status = :transactionStatus OR :transactionStatus IS NULL)
AND (blockSignedAt >= :blockSignedAtStart OR :blockSignedAtStart IS NULL)
AND (blockSignedAt <= :blockSignedAtEnd OR :blockSignedAtEnd IS NULL);

getTransactionsByAccountIdPaged:
SELECT *
FROM TransactionsEntity
WHERE accountId = :accountId
AND blockchain_uid = :blockchainUid
AND (transactionType = :transactionType OR :transactionType IS NULL)
AND (status = :transactionStatus OR :transactionStatus IS NULL)
AND (blockSignedAt >= :blockSignedAtStart OR :blockSignedAtStart IS NULL)
AND (blockSignedAt <= :blockSignedAtEnd OR :blockSignedAtEnd IS NULL)
ORDER BY blockSignedAt DESC
LIMIT :limit OFFSET :offset;

getTransactionsByTxHash:
SELECT * FROM TransactionsEntity WHERE transactionHash = :txHash AND blockchain_uid = :blockchainUid AND accountId = :accountId;

getPendingTransactionsByBlockchainUid:
SELECT * FROM TransactionsEntity WHERE status = 'PENDING' AND blockchain_uid = :blockchainUid;

insertTransaction:
INSERT OR REPLACE INTO TransactionsEntity(
    blockHeight,
    blockSignedAt,
    feesPaid,
    fromAddress,
    fromAddressLabel,
    gasContractAddress,
    gasContractDecimals,
    gasContractName,
    gasContractTickerSymbol,
    gasLogoUrl,
    gasOffered,
    gasPrice,
    gasQuote,
    gasQuoteRate,
    gasSpent,
    minerAddress,
    prettyGasQuote,
    prettyValueQuote,
    status,
    toAddress,
    toAddressLabel,
    transactionHash,
    txOffset,
    value,
    valueQuote,
    accountId,
    transactionType,
    logEvents,
    blockchain_uid,
    is_nft_transaction,
    nft_transfers,
    erc20_transfers,
    native_transfers
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

updateTransactionStatus:
UPDATE TransactionsEntity SET status = ? WHERE transactionHash IN ? AND blockchain_uid = ? AND accountId = ?;

clearAllTransactions:
DELETE FROM TransactionsEntity;

-- TABLE REMOTE KEY ENTITY

CREATE TABLE IF NOT EXISTS RemoteKeyEntity (
    query TEXT PRIMARY KEY,
    lastRequestedPage TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL
);

insertRemoteKey:
INSERT OR REPLACE INTO RemoteKeyEntity (query, lastRequestedPage, blockchain_uid)
VALUES (?, ?, ?);

getRemoteKeyByQuery:
SELECT lastRequestedPage
FROM RemoteKeyEntity
WHERE query = ? AND blockchain_uid = ?;

deleteRemoteKeyByQuery:
DELETE FROM RemoteKeyEntity
WHERE query = ? AND blockchain_uid = ?;

clearAllRemoteKeys:
DELETE FROM RemoteKeyEntity;

-- TABLE TRANSACTION METADATA

CREATE TABLE IF NOT EXISTS TransactionMetadataEntity (
    address TEXT NOT NULL,
    blockchainUid TEXT NOT NULL,
    lastSynchedTimestamp INTEGER NOT NULL,
    PRIMARY KEY (address, blockchainUid)
);

insertTransactionMetadata:
