    uuid TEXT PRIMARY KEY NOT NULL,
    title TEXT,
    description TEXT,
    iconUrl TEXT,
    bannerUrl TEXT,
    chainId TEXT,
    redirectLink TEXT
);

selectAllDApp:
SELECT * FROM DAppEntity;

insertDApp:
INSERT  INTO DAppEntity(uuid, title, description, iconUrl, bannerUrl, chainId, redirectLink)
