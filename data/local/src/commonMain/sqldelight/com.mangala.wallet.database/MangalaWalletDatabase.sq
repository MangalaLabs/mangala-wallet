-- TABLE NftCollectionEntity

CREATE TABLE IF NOT EXISTS NftCollectionEntity (
    type TEXT NOT NULL,
    contractName TEXT NOT NULL,
    contractTickerSymbol TEXT NOT NULL,
    contractAddress TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    accountId TEXT NOT NULL,
    PRIMARY KEY (blockchain_uid, accountId, contractAddress),
    FOREIGN KEY(accountId) REFERENCES AccountEntity(id) ON DELETE CASCADE
);

insertNftCollection:
INSERT OR IGNORE INTO NftCollectionEntity (
    contractName,
    type,
    contractTickerSymbol,
    contractAddress,
    blockchain_uid,
    accountId
) VALUES (?,?, ?, ?, ?, ?);

deleteNftCollectionsByAccountIdAndBlockchainUid:
DELETE FROM NftCollectionEntity WHERE accountId = ? AND blockchain_uid = ?;

deleteNftById:
DELETE FROM NftEntity WHERE tokenId = ? AND blockchain_uid = ? AND accountId = ? AND collectionContractAddress = ?;

getNftCollectionsByAccountIdAndBlockchainUid:
SELECT * FROM NftCollectionEntity WHERE accountId = ? AND blockchain_uid = ?;

getNftCollectionByAccountIdAndBlockchainUidAndContractAddress:
SELECT * FROM NftCollectionEntity WHERE accountId = ? AND blockchain_uid = ? AND contractAddress = ?;

getNftCollectionByAccountIdAndBlockchainUidAndContractAddressJoin:
SELECT *
FROM NftCollectionEntity
LEFT JOIN NftEntity ON NftCollectionEntity.contractAddress = NftEntity.collectionContractAddress
AND NftCollectionEntity.blockchain_uid = NftEntity.blockchain_uid
AND NftCollectionEntity.accountId = NftEntity.accountId
WHERE NftCollectionEntity.accountId = ?
AND NftCollectionEntity.blockchain_uid = ?;

-- TABLE NftEntity

CREATE TABLE IF NOT EXISTS NftEntity (
    tokenId TEXT NOT NULL,
    tokenUrl TEXT NOT NULL,
    name TEXT NOT NULL,
    description TEXT NOT NULL,
    image TEXT NOT NULL,
    attributes TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    accountId TEXT NOT NULL,
    isFavorite INTEGER NOT NULL DEFAULT 0,
    collectionContractAddress TEXT NOT NULL,
    PRIMARY KEY (tokenId, blockchain_uid, accountId, collectionContractAddress),
    FOREIGN KEY(blockchain_uid, accountId, collectionContractAddress) REFERENCES NftCollectionEntity(blockchain_uid, accountId, contractAddress) ON DELETE CASCADE
);

getNft:
SELECT * FROM NftEntity WHERE tokenId = ? AND blockchain_uid = ? AND accountId = ? AND collectionContractAddress = ?;

getNfts:
SELECT * FROM NftEntity WHERE blockchain_uid = ? AND accountId = ? AND collectionContractAddress = ?;

insertNft:
INSERT OR REPLACE INTO NftEntity (tokenId, tokenUrl, name, description, image, attributes, blockchain_uid, accountId, collectionContractAddress)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

upsertNft {
    UPDATE NftEntity
    SET tokenUrl = :tokenUrl, name = :name, description = :description, image = :image, attributes = :attributes
    WHERE tokenId = :tokenId AND blockchain_uid = :blockchain_uid AND accountId = :accountId AND collectionContractAddress = :collectionContractAddress;

    INSERT OR IGNORE INTO NftEntity (tokenId, tokenUrl, name, description, image, attributes, blockchain_uid, accountId, collectionContractAddress)
    VALUES (:tokenId, :tokenUrl, :name, :description, :image, :attributes, :blockchain_uid, :accountId, :collectionContractAddress);
}

getNftFavoriteStatus:
SELECT isFavorite FROM NftEntity WHERE tokenId = ? AND blockchain_uid = ? AND accountId = ? AND collectionContractAddress = ?;

updateNftFavoriteStatus:
UPDATE NftEntity SET isFavorite = ? WHERE tokenId = ? AND blockchain_uid = ? AND accountId = ? AND collectionContractAddress = ?;

deleteNftsByAccountIdAndBlockchainUid:
DELETE FROM NftEntity WHERE blockchain_uid = ? AND accountId = ?;

-- TABLE NftCacheMetadataEntity

CREATE TABLE IF NOT EXISTS NftCacheMetadataEntity(
    accountId TEXT NOT NULL,
    blockchainUid TEXT NOT NULL,
    lastSynchedTimestamp INTEGER NOT NULL,
    PRIMARY KEY (accountId, blockchainUid),
    FOREIGN KEY(accountId) REFERENCES AccountEntity(id) ON DELETE CASCADE
);

insertOrReplaceNftCacheMetadata:
INSERT OR REPLACE INTO NftCacheMetadataEntity(accountId, blockchainUid, lastSynchedTimestamp)
VALUES (?, ?, ?);

getNftCacheLastSynchedTimestamp:
SELECT lastSynchedTimestamp FROM NftCacheMetadataEntity WHERE accountId = ? AND blockchainUid = ?;

-- Clear all NFT data
clearAllNftEntities:
DELETE FROM NftEntity;

clearAllNftCollectionEntities:
DELETE FROM NftCollectionEntity;

clearAllNftCacheMetadataEntities:
DELETE FROM NftCacheMetadataEntity;

-- TABLE PORTFOLIO ENTITY

CREATE TABLE IF NOT EXISTS PortfolioEntity (
    user_id TEXT NOT NULL,
    network_id INTEGER NOT NULL,
    portfolio_id TEXT NOT NULL,
    balance_usdt TEXT NOT NULL,
    pnl_24h_usdt TEXT NOT NULL,
    pnl_24h_percent TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    updated_at INTEGER NOT NULL,
    PRIMARY KEY (user_id, network_id, portfolio_id)
);

insertOrReplacePortfolio:
INSERT OR REPLACE INTO PortfolioEntity(user_id, network_id, portfolio_id, balance_usdt, pnl_24h_usdt, pnl_24h_percent, created_at, updated_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

getPortfolioByUserIdAndNetworkId:
SELECT * FROM PortfolioEntity WHERE user_id = ? AND network_id = ?;

getAllPortfoliosByUserId:
SELECT * FROM PortfolioEntity WHERE user_id = ?;

deletePortfolioByUserIdAndNetworkId:
DELETE FROM PortfolioEntity WHERE user_id = ? AND network_id = ?;

-- TABLE PORTFOLIO ACCOUNT ENTITY

CREATE TABLE IF NOT EXISTS PortfolioAccountEntity (
    account_id TEXT NOT NULL,
    user_id TEXT NOT NULL,
    network_id INTEGER NOT NULL,
    address TEXT NOT NULL,
    label TEXT NOT NULL,
    created_at TEXT NOT NULL,
    balance_usdt TEXT NOT NULL,
    pnl_24h_usdt TEXT NOT NULL,
    pnl_24h_percent TEXT NOT NULL,
    PRIMARY KEY (account_id, user_id, network_id),
    FOREIGN KEY(user_id, network_id) REFERENCES PortfolioEntity(user_id, network_id) ON DELETE CASCADE
);

insertOrReplacePortfolioAccount:
INSERT OR REPLACE INTO PortfolioAccountEntity(account_id, user_id, network_id, address, label, created_at, balance_usdt, pnl_24h_usdt, pnl_24h_percent)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getPortfolioAccountsByUserIdAndNetworkId:
SELECT * FROM PortfolioAccountEntity WHERE user_id = ? AND network_id = ?;

getPortfolioAccountByAddress:
SELECT * FROM PortfolioAccountEntity WHERE address = ?;

deletePortfolioAccountsByUserIdAndNetworkId:
DELETE FROM PortfolioAccountEntity WHERE user_id = ? AND network_id = ?;

-- TABLE PORTFOLIO TOKEN ENTITY

CREATE TABLE IF NOT EXISTS PortfolioTokenEntity (
    token_key TEXT NOT NULL,
    account_id TEXT NOT NULL,
    user_id TEXT NOT NULL,
    network_id INTEGER NOT NULL,
    symbol TEXT NOT NULL,
    name TEXT NOT NULL,
    quantity TEXT NOT NULL,
    balance_usdt TEXT NOT NULL,
    price_usdt TEXT NOT NULL,
    pnl_24h_usdt TEXT NOT NULL,
    pnl_24h_percent TEXT NOT NULL,
    PRIMARY KEY (token_key, account_id, user_id, network_id),
    FOREIGN KEY(account_id, user_id, network_id) REFERENCES PortfolioAccountEntity(account_id, user_id, network_id) ON DELETE CASCADE
);

insertOrReplacePortfolioToken:
INSERT OR REPLACE INTO PortfolioTokenEntity(token_key, account_id, user_id, network_id, symbol, name, quantity, balance_usdt, price_usdt, pnl_24h_usdt, pnl_24h_percent)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getPortfolioTokensByAccountId:
SELECT * FROM PortfolioTokenEntity WHERE account_id = ? AND user_id = ? AND network_id = ?;

deletePortfolioTokensByAccountId:
DELETE FROM PortfolioTokenEntity WHERE account_id = ? AND user_id = ? AND network_id = ?;

-- TABLE PORTFOLIO PRICING CONTEXT ENTITY

CREATE TABLE IF NOT EXISTS PortfolioPricingContextEntity (
    user_id TEXT NOT NULL,
    network_id INTEGER NOT NULL,
    as_of TEXT NOT NULL,
    quote_currency TEXT NOT NULL,
    status TEXT NOT NULL,
    updated_at INTEGER NOT NULL,
    PRIMARY KEY (user_id, network_id),
    FOREIGN KEY(user_id, network_id) REFERENCES PortfolioEntity(user_id, network_id) ON DELETE CASCADE
);

insertOrReplacePricingContext:
INSERT OR REPLACE INTO PortfolioPricingContextEntity(user_id, network_id, as_of, quote_currency, status, updated_at)
VALUES (?, ?, ?, ?, ?, ?);

getPricingContextByUserIdAndNetworkId:
SELECT * FROM PortfolioPricingContextEntity WHERE user_id = ? AND network_id = ?;

-- TABLE PORTFOLIO TOKEN PRICE ENTITY

CREATE TABLE IF NOT EXISTS PortfolioTokenPriceEntity (
    token_key TEXT NOT NULL,
    user_id TEXT NOT NULL,
    network_id INTEGER NOT NULL,
    spot TEXT NOT NULL,
    price_24h_ago TEXT NOT NULL,
    last_updated TEXT NOT NULL,
    source TEXT NOT NULL,
    PRIMARY KEY (token_key, user_id, network_id),
    FOREIGN KEY(user_id, network_id) REFERENCES PortfolioPricingContextEntity(user_id, network_id) ON DELETE CASCADE
);

insertOrReplacePortfolioTokenPrice:
INSERT OR REPLACE INTO PortfolioTokenPriceEntity(token_key, user_id, network_id, spot, price_24h_ago, last_updated, source)
VALUES (?, ?, ?, ?, ?, ?, ?);

getPortfolioTokenPricesByUserIdAndNetworkId:
SELECT * FROM PortfolioTokenPriceEntity WHERE user_id = ? AND network_id = ?;
