graph TB
    %% Actors
    User((User))
    ColdWalletUser((Cold Wallet User))
    DAppUser((DApp User))
    System((System))

    %% Use Cases - Authentication & Setup
    subgraph "Authentication & Setup"
        UC1[Authenticate with PIN/Biometrics]
        UC2[Setup New PIN]
        UC3[Enable Biometric Authentication]
        UC4[Recover Forgotten PIN]
        UC5[Create New Wallet]
        UC6[Backup Wallet with Recovery Phrase]
        UC7[Restore Wallet from Recovery Phrase]
    end

    %% Use Cases - Wallet Management
    subgraph "Wallet Management"
        UC8[View Portfolio Overview]
        UC9[Manage Multiple Accounts]
        UC10[Add New Account]
        UC11[Import Account via Private Key]
        UC12[View Account Details]
        UC13[Sync Accounts Between Devices]
        UC14[View Transaction History]
        UC15[Filter Transaction History]
    end

    %% Use Cases - Token Operations
    subgraph "Token Operations"
        UC16[Send Cryptocurrency]
        UC17[Receive Cryptocurrency]
        UC18[Swap Tokens]
        UC19[Select Token for Operations]
        UC20[Set Transaction Amount]
        UC21[Configure Transaction Fees]
        UC22[Verify and Confirm Transaction]
        UC23[View Transaction Success]
    end

    %% Use Cases - NFT Management
    subgraph "NFT Management"
        UC24[View NFT Collection]
        UC25[Import New NFT]
        UC26[Send NFT to Another Address]
        UC27[View NFT Details]
        UC28[Filter NFTs by Chain]
    end

    %% Use Cases - Antelope Blockchain Features
    subgraph "Antelope Blockchain Features"
        UC29[Manage Antelope Account Resources]
        UC30[Stake/Unstake CPU and NET]
        UC31[Buy/Sell RAM]
