@startuml Mangala Wallet Use Case Diagram

!theme plain
skinparam actor {
    BackgroundColor lightblue
    BorderColor darkblue
}
skinparam usecase {
    BackgroundColor lightgray
    BorderColor black
}

' Actors
:User: as User
:Cold Wallet User: as ColdUser
:DApp User: as DAppUser
:System: as System

' Authentication & Setup Use Cases
rectangle "Authentication & Setup" {
    (Authenticate with PIN/Biometrics) as UC1
    (Setup New PIN) as UC2
    (Enable Biometric Authentication) as UC3
    (Recover Forgotten PIN) as UC4
    (Create New Wallet) as UC5
    (Backup Wallet with Recovery Phrase) as UC6
    (Restore Wallet from Recovery Phrase) as UC7
}

' Wallet Management Use Cases
rectangle "Wallet Management" {
    (View Portfolio Overview) as UC8
    (Manage Multiple Accounts) as UC9
    (Add New Account) as UC10
    (Import Account via Private Key) as UC11
    (View Account Details) as UC12
    (Sync Accounts Between Devices) as UC13
    (View Transaction History) as UC14
    (Filter Transaction History) as UC15
}

' Token Operations Use Cases
rectangle "Token Operations" {
    (Send Cryptocurrency) as UC16
    (Receive Cryptocurrency) as UC17
    (Swap Tokens) as UC18
    (Select Token for Operations) as UC19
    (Set Transaction Amount) as UC20
    (Configure Transaction Fees) as UC21
    (Verify and Confirm Transaction) as UC22
    (View Transaction Success) as UC23
}

' NFT Management Use Cases
rectangle "NFT Management" {
    (View NFT Collection) as UC24
    (Import New NFT) as UC25
    (Send NFT to Another Address) as UC26
    (View NFT Details) as UC27
    (Filter NFTs by Chain) as UC28
}

' Antelope Blockchain Features Use Cases
rectangle "Antelope Blockchain Features" {
    (Manage Antelope Account Resources) as UC29
    (Stake/Unstake CPU and NET) as UC30
    (Buy/Sell RAM) as UC31
    (Transfer RAM) as UC32
    (Rent Resources via REX) as UC33
    (Power Up Resources) as UC34
    (Manage Account Permissions) as UC35
    (Create/Update Permissions) as UC36
    (Link/Unlink Authorizations) as UC37
    (Create Multisig Proposals) as UC38
    (Approve/Reject Multisig Proposals) as UC39
    (Backup Antelope Account) as UC40
    (Create EOS Account via EVM) as UC41
    (Import EOS Account via EVM) as UC42
}

' Settings & Configuration Use Cases
rectangle "Settings & Configuration" {
    (Change App Theme) as UC43
    (Select Language) as UC44
    (Set Default Currency) as UC45
    (Manage Custom Networks) as UC46
    (Configure Notifications) as UC47
    (Manage Security Settings) as UC48
    (Manage Contacts) as UC49
    (Add/Edit Contacts) as UC50
    (View App Information) as UC51
}

' Browser & DApp Integration Use Cases
rectangle "Browser & DApp Integration" {
    (Browse Web3 Sites) as UC52
    (Connect to DApps) as UC53
    (Sign Messages for DApps) as UC54
    (Confirm DApp Transactions) as UC55
    (Switch Blockchain Networks) as UC56
    (Manage WalletConnect Sessions) as UC57
    (Sign ESR Requests) as UC58
}

' Cold Wallet Features Use Cases
rectangle "Cold Wallet Features" {
    (Generate Transaction QR Code) as UC59
    (Scan Transaction QR Code) as UC60
    (Sign Transactions Offline) as UC61
    (Display Signed Transaction QR) as UC62
    (Sync Account Data via QR) as UC63
}

' Crypto Payments Use Cases
rectangle "Crypto Payments" {
    (Pay with Cryptocurrency) as UC64
    (Select Payment Method) as UC65
    (Select Payment Network) as UC66
    (Configure Token Allowance) as UC67
    (Review Payment Details) as UC68
    (Handle Payment Errors) as UC69
}

' Account Creation Use Cases
rectangle "Account Creation" {
    (Create Antelope Account) as UC70
    (Select Account Type) as UC71
    (Choose Account Name) as UC72
    (Pay for Account Creation) as UC73
    (Create Account for Friend) as UC74
    (Purchase Account via IAP) as UC75
}

