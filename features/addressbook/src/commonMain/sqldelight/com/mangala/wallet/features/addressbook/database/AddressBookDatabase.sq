-- AddressBookDatabase.sq
-- Định nghĩa SQLDelight cho Address Book Database

-- Import thư viện cần thiết
import kotlin.Boolean;

-- Bảng Contact
CREATE TABLE IF NOT EXISTS contacts (
  id TEXT PRIMARY KEY NOT NULL,
  name TEXT NOT NULL,
  notes TEXT,
  solar_birthday TEXT, -- Sử dụng TEXT cho ngày tháng, sẽ được chuyển đổi qua adapter
  lunar_birthday TEXT,
  is_sensitive INTEGER AS Boolean DEFAULT 0,
  security_level TEXT DEFAULT 'NORMAL', -- NORMAL, HIGH, MAXIMUM
  privacy_display_mode TEXT DEFAULT 'FULL', -- FULL, HIDDEN, SECRET
  auth_requirement TEXT DEFAULT 'NONE', -- NONE, BIOMETRIC, BIOMETRIC_PIN
  created_at INTEGER NOT NULL, -- Unix timestamp
  updated_at INTEGER NOT NULL,
  last_viewed_at INTEGER,
  sync_status TEXT DEFAULT 'LOCAL_ONLY', -- SYNCED, LOCAL_ONLY, PENDING
  encrypted_data TEXT,
  avatar TEXT
);

-- Bảng Blockchain Types
CREATE TABLE IF NOT EXISTS blockchain_types (
  id TEXT PRIMARY KEY NOT NULL,
  name TEXT NOT NULL,
  symbol TEXT NOT NULL,
  address_format TEXT,
  validation_regex TEXT,
  icon TEXT,
  color TEXT,
  network_type TEXT NOT NULL DEFAULT 'mainnet', -- 'mainnet' hoặc 'testnet'
  is_active INTEGER AS Boolean DEFAULT 1,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

-- Bảng Wallet Address
CREATE TABLE IF NOT EXISTS wallet_addresses (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  blockchain_type_id TEXT NOT NULL,
  address TEXT NOT NULL,
  alias TEXT,
  wallet_type TEXT,
  is_sensitive INTEGER AS Boolean DEFAULT 0,
  is_primary INTEGER AS Boolean DEFAULT 0,
  is_verified INTEGER AS Boolean DEFAULT 0,
  verified_date TEXT, -- Sử dụng TEXT cho ngày tháng, sẽ được chuyển đổi qua adapter
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (blockchain_type_id) REFERENCES blockchain_types(id)
);

-- Bảng Tag
CREATE TABLE IF NOT EXISTS tags (
  id TEXT PRIMARY KEY NOT NULL,
  name TEXT NOT NULL,
  color TEXT NOT NULL DEFAULT '#CCCCCC',
  text_color TEXT DEFAULT NULL, -- Added text_color column for the text color
  icon TEXT,
  is_deleted INTEGER AS Boolean DEFAULT 0 NOT NULL , -- soft delete for the tag, if true, it will not be shown in the UI
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

-- Bảng liên kết Contact và Tag
CREATE TABLE IF NOT EXISTS contact_tags (
  contact_id TEXT NOT NULL,
  tag_id TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  PRIMARY KEY (contact_id, tag_id),
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (tag_id) REFERENCES tags(id) ON DELETE CASCADE
);

-- Bảng Group
CREATE TABLE IF NOT EXISTS groups (
  id TEXT PRIMARY KEY NOT NULL,
  name TEXT NOT NULL,
  main_blockchain_id TEXT,
  description TEXT,
  icon TEXT,
  color TEXT,
  privacy_level TEXT DEFAULT 'PUBLIC', -- PUBLIC, PRIVATE, SECRET
  security_level TEXT DEFAULT 'NORMAL', -- NORMAL, HIGH, MAXIMUM
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (main_blockchain_id) REFERENCES blockchain_types(id)
);

-- Bảng liên kết Group và Wallet
CREATE TABLE IF NOT EXISTS group_wallet (
  group_id TEXT NOT NULL,
  wallet_address_id TEXT NOT NULL,
  contact_id TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  PRIMARY KEY (group_id, wallet_address_id),
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (group_id) REFERENCES groups(id),
  FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

-- Bảng Transaction History
CREATE TABLE IF NOT EXISTS transaction_history (
  id TEXT PRIMARY KEY NOT NULL,
  from_address TEXT NOT NULL,
  to_address TEXT NOT NULL,
  blockchain_type_id TEXT NOT NULL,
  amount TEXT NOT NULL,
  token_symbol TEXT NOT NULL,
  transaction_hash TEXT NOT NULL,
  status TEXT NOT NULL, -- PENDING, CONFIRMED, FAILED
  timestamp INTEGER NOT NULL,
  fee TEXT,
  note TEXT,
  is_from_imported_wallet INTEGER NOT NULL DEFAULT 0,
  FOREIGN KEY (blockchain_type_id) REFERENCES blockchain_types(id)
);

-- Bảng liên kết Contact và Transaction
CREATE TABLE IF NOT EXISTS contact_transactions (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  transaction_id TEXT NOT NULL,
  wallet_address_id TEXT NOT NULL,
  is_sender INTEGER AS Boolean NOT NULL,
  created_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (transaction_id) REFERENCES transaction_history(id) ON DELETE CASCADE,
  FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

-- Bảng Security Audit Logs
CREATE TABLE IF NOT EXISTS security_audit_logs (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT,
  wallet_address_id TEXT,
  action TEXT NOT NULL, -- CREATE, VIEW, EDIT, DELETE, EXPORT, VIEW_SENSITIVE, PRIVACY_CHANGE, AUTH_FAILURE
  details TEXT,
  device_info TEXT,
  timestamp INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

-- Bảng User Settings
CREATE TABLE IF NOT EXISTS user_settings (
  id TEXT PRIMARY KEY NOT NULL,
  privacy_mode_enabled INTEGER AS Boolean DEFAULT 0,
  default_privacy_display TEXT DEFAULT 'PARTIAL', -- FULL, PARTIAL, HIDDEN
  biometric_auth_enabled INTEGER AS Boolean DEFAULT 0,
  two_factor_auth_enabled INTEGER AS Boolean DEFAULT 0,
  sync_enabled INTEGER AS Boolean DEFAULT 0,
  default_sort_option TEXT DEFAULT 'A_Z', -- A_Z, Z_A, NEWEST, OLDEST, BLOCKCHAIN
  theme TEXT DEFAULT 'SYSTEM', -- LIGHT, DARK, SYSTEM
  reminder_settings TEXT,
  safe_zones TEXT,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

-- Bảng Transaction Reminders
CREATE TABLE IF NOT EXISTS transaction_reminders (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  wallet_address_id TEXT,
  title TEXT NOT NULL,
  description TEXT,
  reminder_date INTEGER NOT NULL,
  recurrence TEXT DEFAULT 'NONE', -- NONE, DAILY, WEEKLY, MONTHLY, YEARLY
  status TEXT DEFAULT 'PENDING', -- PENDING, COMPLETED, CANCELLED
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE,
  FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

-- Bảng AppVersion
CREATE TABLE IF NOT EXISTS app_version (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  version_code INTEGER NOT NULL,
  version_name TEXT NOT NULL,
  schema_version INTEGER NOT NULL,
  last_updated INTEGER NOT NULL, -- Unix timestamp
  migration_notes TEXT
);

-- Bảng Offline Queue
CREATE TABLE IF NOT EXISTS offline_queue (
  id TEXT PRIMARY KEY NOT NULL,
  action_type TEXT NOT NULL, -- CREATE, UPDATE, DELETE
  entity_type TEXT NOT NULL, -- CONTACT, WALLET, TAG, GROUP, etc.
  entity_id TEXT NOT NULL,
  queue_data TEXT NOT NULL,
  attempt_count INTEGER DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL
);

-- Bảng Token Information
CREATE TABLE IF NOT EXISTS token_information (
  id TEXT PRIMARY KEY NOT NULL,
  blockchain_type_id TEXT NOT NULL,
  token_name TEXT NOT NULL,
  token_symbol TEXT NOT NULL,
  contract_address TEXT,
  icon TEXT,
  decimals INTEGER NOT NULL DEFAULT 18,
  is_native INTEGER AS Boolean DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (blockchain_type_id) REFERENCES blockchain_types(id)
);

-- Bảng Physical Addresses
CREATE TABLE IF NOT EXISTS physical_addresses (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  street_address TEXT,
  ward TEXT,
  district TEXT,
  city TEXT,
  state_province TEXT,
  postal_code TEXT,
  country TEXT,
  is_primary INTEGER AS Boolean DEFAULT 1,
  address_type TEXT,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Phone Numbers
CREATE TABLE IF NOT EXISTS phone_numbers (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  phone_number TEXT NOT NULL,
  label TEXT,
  is_primary INTEGER AS Boolean DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Email Addresses
CREATE TABLE IF NOT EXISTS email_addresses (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  email TEXT NOT NULL,
  label TEXT,
  is_primary INTEGER AS Boolean DEFAULT 0,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Related Names
CREATE TABLE IF NOT EXISTS related_names (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  name TEXT NOT NULL,
  relationship TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Important Dates
CREATE TABLE IF NOT EXISTS important_dates (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  date INTEGER NOT NULL, -- Unix timestamp hoặc YYYYMMDD
  description TEXT NOT NULL,
  calendar_type TEXT DEFAULT 'SOLAR', -- SOLAR hoặc LUNAR
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Favorites
CREATE TABLE IF NOT EXISTS favorites (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL UNIQUE,
  display_order INTEGER NOT NULL,
  created_at INTEGER NOT NULL,
  updated_at INTEGER,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Bảng Social Profiles
CREATE TABLE IF NOT EXISTS social_profiles (
  id TEXT PRIMARY KEY NOT NULL,
  contact_id TEXT NOT NULL,
  platform TEXT NOT NULL, -- e.g., "Twitter", "Facebook", "Instagram", "Telegram"
  username TEXT NOT NULL,
  url TEXT,
  created_at INTEGER NOT NULL,
  updated_at INTEGER NOT NULL,
  FOREIGN KEY (contact_id) REFERENCES contacts(id) ON DELETE CASCADE
);

-- Các Query để lấy dữ liệu

-- Lấy contact với đầy đủ thông tin
getContactById:
SELECT * FROM contacts WHERE id = ?;

-- Lấy tất cả contacts và phân trang để tối ưu hiệu suất
getAllContactsPaged:
SELECT * FROM contacts
ORDER BY
  CASE WHEN :sortOrder = 'A_Z' THEN name END ASC,
  CASE WHEN :sortOrder = 'Z_A' THEN name END DESC,
  CASE WHEN :sortOrder = 'NEWEST' THEN created_at END DESC,
  CASE WHEN :sortOrder = 'OLDEST' THEN created_at END ASC
LIMIT :limit OFFSET :offset;

-- Tìm kiếm contacts theo tên
searchContacts:
SELECT * FROM contacts
WHERE name LIKE '%' || :query || '%'
ORDER BY name ASC
LIMIT :limit OFFSET :offset;

-- Lấy wallet addresses của một contact
getWalletAddressesByContactId:
SELECT * FROM wallet_addresses WHERE contact_id = ?;

-- Lấy blockchain type
getBlockchainTypeById:
SELECT * FROM blockchain_types WHERE id = ?;

-- Lấy tất cả blockchain types
getAllBlockchainTypes:
SELECT * FROM blockchain_types WHERE is_active = 1 ORDER BY name ASC;

-- Lấy tags của một contact
getTagsByContactId:
SELECT t.* FROM tags t
INNER JOIN contact_tags ct ON t.id = ct.tag_id
WHERE ct.contact_id = ?
ORDER BY t.name ASC;

-- Lấy tất cả tags
getAllTags:
SELECT * FROM tags ORDER BY name ASC;

-- Lấy contacts theo tag
getContactsByTagId:
SELECT c.* FROM contacts c
INNER JOIN contact_tags ct ON c.id = ct.contact_id
WHERE ct.tag_id = ?
ORDER BY c.name ASC
LIMIT :limit OFFSET :offset;

-- Lấy groups mà contact thuộc về
getGroupsByContactId:
SELECT g.* FROM groups g
INNER JOIN group_wallet gw ON g.id = gw.group_id
WHERE gw.contact_id = ?
ORDER BY g.name ASC;

-- Lấy tất cả groups
getGroupById:
SELECT * FROM groups WHERE id = :id ORDER BY name ASC;

-- Filter groups with pagination (matching contacts pattern)
filterGroups:
SELECT
    g.id AS group_id,
    g.name AS group_name,
    g.description AS group_description,
    g.icon AS group_icon,
    g.color AS group_color,
    g.privacy_level AS privacy_level,
    g.security_level AS security_level,
    g.created_at AS created_at,
    g.updated_at AS updated_at,
    bt.id AS main_blockchain_id,
    bt.name AS main_blockchain_name,
    bt.symbol AS main_blockchain_symbol,
    bt.icon AS main_blockchain_icon,
    COUNT(DISTINCT cg.wallet_address_id) AS wallet_address_count
FROM
    groups g
LEFT JOIN
    blockchain_types bt ON g.main_blockchain_id = bt.id
LEFT JOIN
    group_wallet cg ON g.id = cg.group_id
WHERE
    (:query = '' OR g.name LIKE '%' || :query || '%' OR g.description LIKE '%' || :query || '%')
GROUP BY
    g.id,
    g.name,
    g.description,
    g.icon,
    g.color,
    g.privacy_level,
    g.security_level,
    g.created_at,
    g.updated_at,
    bt.name,
    bt.symbol,
    bt.icon
ORDER BY
    g.name COLLATE NOCASE ASC
LIMIT :limit OFFSET :offset;

-- Lấy contacts trong một group
getContactsByGroupId:
SELECT c.* FROM contacts c
INNER JOIN group_wallet gw ON c.id = gw.contact_id
WHERE gw.group_id = ?
ORDER BY c.name ASC
LIMIT :limit OFFSET :offset;

-- Lấy wallet address được sử dụng trong group
getWalletAddressForContactInGroup:
SELECT wa.* FROM wallet_addresses wa
INNER JOIN group_wallet gw ON wa.id = gw.wallet_address_id
WHERE gw.contact_id = ? AND gw.group_id = ?;

-- Lấy transaction history của một contact
getTransactionHistoryByContactId:
SELECT th.* FROM transaction_history th
INNER JOIN contact_transactions ct ON th.id = ct.transaction_id
WHERE ct.contact_id = ?
ORDER BY th.timestamp DESC
LIMIT :limit OFFSET :offset;

-- Lấy transaction history của một wallet address
getTransactionHistoryByWalletAddress:
SELECT th.* FROM transaction_history th
WHERE th.from_address = ? OR th.to_address = ?
ORDER BY th.timestamp DESC
LIMIT :limit OFFSET :offset;

-- Lấy transaction reminders của một contact
getRemindersByContactId:
SELECT * FROM transaction_reminders
WHERE contact_id = ?
ORDER BY reminder_date ASC;

-- Lấy physical addresses của một contact
getPhysicalAddressesByContactId:
SELECT * FROM physical_addresses WHERE contact_id = ?;

-- Lấy phone numbers của một contact
getPhoneNumbersByContactId:
SELECT * FROM phone_numbers WHERE contact_id = ?;

-- Lấy email addresses của một contact
getEmailAddressesByContactId:
SELECT * FROM email_addresses WHERE contact_id = ?;

-- Lấy related names của một contact
getRelatedNamesByContactId:
SELECT * FROM related_names WHERE contact_id = ?;

-- Lấy important dates của một contact
getImportantDatesByContactId:
SELECT * FROM important_dates WHERE contact_id = ?;

-- Lấy danh sách favorites
getFavoriteContacts:
SELECT c.* FROM contacts c
INNER JOIN favorites f ON c.id = f.contact_id
ORDER BY f.display_order ASC
LIMIT :limit OFFSET :offset;

-- Lấy recent contacts (đã xem gần đây)
getRecentContacts:
SELECT * FROM contacts
WHERE last_viewed_at IS NOT NULL
ORDER BY last_viewed_at DESC
LIMIT :limit;

countTransactions:
SELECT count(*) FROM transaction_history;

-- Lấy pending transactions
getPendingTransactions:
SELECT * FROM transaction_history
WHERE status = 'PENDING'
ORDER BY timestamp DESC;

-- Lấy contacts cần đồng bộ
getContactsToSync:
SELECT * FROM contacts
WHERE sync_status = 'PENDING'
ORDER BY updated_at ASC;

-- Lấy offline queue
getOfflineQueue:
SELECT * FROM offline_queue
ORDER BY created_at ASC;

-- Lấy audit logs cho một contact
getAuditLogsByContactId:
SELECT * FROM security_audit_logs
WHERE contact_id = ?
ORDER BY timestamp DESC
LIMIT :limit OFFSET :offset;

-- Lấy tất cả user settings
getUserSettings:
SELECT * FROM user_settings
WHERE id = ?;

-- Lấy app version hiện tại
getCurrentAppVersion:
SELECT * FROM app_version
ORDER BY version_code DESC
LIMIT 1;

-- Kiểm tra contact có phải favorite không
isContactFavorite:
SELECT EXISTS(SELECT 1 FROM favorites WHERE contact_id = ?) AS is_favorite;

-- Count tổng số contacts
countAllContacts:
SELECT COUNT(*) FROM contacts;

-- Count số contacts theo tag
countContactsByTagId:
SELECT COUNT(*) FROM contact_tags WHERE tag_id = ?;

-- Count số wallets theo group
countWalletsByGroupId:
SELECT COUNT(*) FROM group_wallet WHERE group_id = ?;

-- Tìm contact từ email
findContactByEmail:
SELECT c.* FROM contacts c
INNER JOIN email_addresses e ON c.id = e.contact_id
WHERE e.email = ?;

-- Tìm contact từ phone number
findContactByPhoneNumber:
SELECT c.* FROM contacts c
INNER JOIN phone_numbers p ON c.id = p.contact_id
WHERE p.phone_number = ?;

-- Tìm contact từ wallet address
findContactByWalletAddress:
SELECT c.* FROM contacts c
INNER JOIN wallet_addresses w ON c.id = w.contact_id
WHERE w.address = ?;

-- Find contact by exact name
findContactByName:
SELECT * FROM contacts
WHERE name = ? COLLATE NOCASE
LIMIT 1;

-- Insert/Update Queries (để sử dụng trong repository)
-- Thêm một contact mới
insertContact:
INSERT INTO contacts(
  id, name, notes, solar_birthday, lunar_birthday, is_sensitive,
  security_level, privacy_display_mode, auth_requirement,
  created_at, updated_at, last_viewed_at, sync_status, encrypted_data, avatar
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Cập nhật một contact
updateContact:
UPDATE contacts
SET name = ?,
    notes = ?,
    solar_birthday = ?,
    lunar_birthday = ?,
    is_sensitive = ?,
    security_level = ?,
    privacy_display_mode = ?,
    auth_requirement = ?,
    updated_at = ?,
    sync_status = ?,
    encrypted_data = ?,
    avatar= ?
WHERE id = ?;

-- Cập nhật thời gian xem contact
updateContactLastViewedAt:
UPDATE contacts
SET last_viewed_at = ?
WHERE id = ?;

-- Thêm wallet address
insertWalletAddress:
INSERT INTO wallet_addresses(
  id, contact_id, blockchain_type_id, address, alias, wallet_type,
  is_sensitive, is_primary, is_verified, verified_date, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Cập nhật wallet address

-- Find group by exact name
findGroupByName:
SELECT * FROM groups
WHERE name = ? COLLATE NOCASE
LIMIT 1;

-- Thêm group
insertGroup:
INSERT INTO groups(
  id, name, main_blockchain_id, description, icon, color,
  privacy_level, security_level, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Cập nhật group
updateGroup:
UPDATE groups
SET name = ?,
    main_blockchain_id = ?,
    description = ?,
    icon = ?,
    color = ?,
    privacy_level = ?,
    security_level = ?,
    updated_at = ?
WHERE id = ?;

-- Thêm wallet vào group
addWalletToGroup:
INSERT INTO group_wallet(group_id, wallet_address_id, contact_id, created_at)
VALUES (?, ?, ?, ?);

-- Xóa wallet khỏi group
removeWalletFromGroup:
DELETE FROM group_wallet
WHERE wallet_address_id = ? AND group_id = ?;

-- Thêm favorite
addFavorite:
INSERT INTO favorites(id, contact_id, display_order, created_at, updated_at)
VALUES (?, ?, ?, ?, ?);

-- Xóa favorite
removeFavorite:
DELETE FROM favorites
WHERE contact_id = ?;

-- Xóa contact
deleteContact:
DELETE FROM contacts WHERE id = ?;

-- Xóa physical address
deletePhysicalAddress:
DELETE FROM physical_addresses WHERE id = ?;

-- Xóa phone number
deletePhoneNumber:
DELETE FROM phone_numbers WHERE id = ?;

-- Xóa email address
deleteEmailAddress:
DELETE FROM email_addresses WHERE id = ?;

-- Xóa wallet address
deleteWalletAddress:
DELETE FROM wallet_addresses WHERE id = ?;

-- Xóa related name
deleteRelatedName:
DELETE FROM related_names WHERE id = ?;

-- Xóa important date
deleteImportantDate:
DELETE FROM important_dates WHERE id = ?;

-- Xóa tag
deleteTag:
DELETE FROM tags WHERE id = ?;

-- Xóa group
deleteGroup:
DELETE FROM groups WHERE id = ?;

-- Lấy danh sách social profiles của một contact
getSocialProfilesByContactId:
SELECT * FROM social_profiles WHERE contact_id = ?;

-- Thêm social profile
insertSocialProfile:
INSERT INTO social_profiles(
  id, contact_id, platform, username, url, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?);

-- Cập nhật social profile
updateSocialProfile:
UPDATE social_profiles
SET platform = ?,
    username = ?,
    url = ?,
    updated_at = ?
WHERE id = ?;

-- Xóa social profile
deleteSocialProfile:
DELETE FROM social_profiles WHERE id = ?;

-- Xóa social profile
deleteSocialProfileByContactId:
DELETE FROM social_profiles WHERE contact_id = ?;

-- Thêm phone number
insertPhoneNumber:
INSERT INTO phone_numbers(
  id, contact_id, phone_number, label, is_primary, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?);

-- Thêm email address
insertEmailAddress:
INSERT INTO email_addresses(
  id, contact_id, email, label, is_primary, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?);

-- Thêm physical address
insertPhysicalAddress:
INSERT INTO physical_addresses(
  id, contact_id, street_address, ward, district, city, state_province, postal_code,
  country, is_primary, address_type, created_at, updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Thêm các query sau vào AddressBookDatabase.sq

-- Lấy danh sách wallet address của một contact
getWalletAddressesForContact:
SELECT
  wa.*,
  bt.name AS network_name,
  bt.symbol AS network_symbol
FROM wallet_addresses wa
JOIN blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE wa.contact_id = ?
ORDER BY wa.is_primary DESC, wa.created_at DESC
LIMIT ? OFFSET ?;

-- Lấy danh sách wallet address theo id
getWalletAddressesById:
SELECT
  wa.*,
  bt.name AS network_name,
  bt.symbol AS network_symbol
FROM wallet_addresses wa
JOIN blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE wa.id = ?;

-- Đếm số wallet address của một contact
countWalletAddressesForContact:
SELECT COUNT(*) FROM wallet_addresses WHERE contact_id = ?;

-- Lấy wallet address mặc định của một contact và blockchain type
getDefaultWalletAddress:
SELECT * FROM wallet_addresses
WHERE contact_id = ?
AND blockchain_type_id = ?
AND is_primary = 1
LIMIT 1;

-- Đặt một wallet address làm mặc định
setWalletAddressAsPrimary:
UPDATE wallet_addresses
SET is_primary = 0
WHERE contact_id = ? AND blockchain_type_id = ?;

-- Lấy wallet address theo blockchain type
getWalletAddressesByBlockchainType:
SELECT
  wa.*,
  bt.name AS network_name,
  bt.symbol AS network_symbol
FROM wallet_addresses wa
JOIN blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE wa.blockchain_type_id = ?
ORDER BY wa.is_primary DESC, wa.created_at DESC
LIMIT ? OFFSET ?;

-- Đặt một wallet address làm mặc định và bỏ mặc định các wallet address khác
-- clearPrimaryWalletForContactAndBlockchainType:
-- UPDATE wallet_addresses
-- SET is_primary = 0
-- WHERE contact_id = ? AND blockchain_type_id = ?;

-- Cập nhật wallet address
updateWalletAddress:
UPDATE wallet_addresses
SET
  address = ?,
  alias = ?,
  wallet_type = ?,
  is_primary = ?,
  is_sensitive = ?,
  is_verified = ?,
  blockchain_type_id = ?,
  verified_date = ?,
  updated_at = ?
WHERE id = ?;

-- Xóa các wallet address của một contact
deleteWalletAddressesByContactId:
