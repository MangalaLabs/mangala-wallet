-- new queries
-- Tag related queries

-- Get all active tags ordered by name
getActiveTags:
SELECT *
FROM tags
WHERE is_deleted = 0
ORDER BY name;

-- Get a tag by ID
getTagById:
SELECT *
FROM tags
WHERE id = ?;

-- Find a tag by name regardless of deleted status
findTagByName:
SELECT *
FROM tags
WHERE name = ?;

-- Insert a new tag
insertTag:
INSERT INTO tags (id, name, color, text_color, icon, is_deleted, created_at, updated_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?);

-- Update an existing tag
updateTag:
UPDATE tags
SET name = ?, color = ?, text_color = ?, icon = ?, updated_at = ?
WHERE id = ?;

-- Mark a tag as deleted (soft delete)
markTagAsDeleted:
UPDATE tags
SET is_deleted = 1, updated_at = ?
WHERE id = ?;

-- Restore a previously deleted tag
restoreTag:
UPDATE tags
SET is_deleted = 0, color = ?, text_color = ?, updated_at = ?
WHERE id = ?;

-- Search active tags by name pattern
searchActiveTags:
SELECT *
FROM tags
WHERE is_deleted = 0 AND name LIKE ?
ORDER BY name;

-- Contact-Tag related queries

-- Check if contact-tag association exists
checkAssociationExists:
SELECT 1
FROM contact_tags
WHERE contact_id = ? AND tag_id = ?
LIMIT 1;

-- Insert contact tag association
insertContactTag:
INSERT INTO contact_tags (contact_id, tag_id, created_at)
VALUES (?, ?, ?);

-- Remove tag from contact
removeTagFromContact:
DELETE FROM contact_tags
WHERE contact_id = ? AND tag_id = ?;

-- Get all tags for a contact, including those that are soft-deleted
getTagsForContact:
SELECT t.*
FROM contact_tags ct
JOIN tags t ON ct.tag_id = t.id
WHERE ct.contact_id = ?
ORDER BY t.name;

-- Get all active tags for a contact (excluding soft-deleted)
getActiveTagsForContact:
SELECT t.*
FROM contact_tags ct
JOIN tags t ON ct.tag_id = t.id
WHERE ct.contact_id = ? AND t.is_deleted = 0
ORDER BY t.name;

countContactAssociatedWithTagByTagId:
SELECT COUNT(*)
FROM contact_tags
WHERE tag_id = ?;

-- Get all contact IDs with a specific tag
getContactIdsWithTag:
SELECT ct.contact_id
FROM contact_tags ct
INNER JOIN contacts c ON ct.contact_id = c.id
WHERE ct.tag_id = ?;

-- Get contact IDs with any of the specified tags (OR logic)
getContactIdsWithAnyTag:
SELECT DISTINCT contact_id
FROM contact_tags
WHERE tag_id IN ?;

-- Get count of tags per contact
getTagCountForContact:
SELECT COUNT(*)
FROM contact_tags
WHERE contact_id = ?;

-- Get most used tags (for suggestions)
getMostUsedTags:
SELECT t.*, COUNT(ct.contact_id) AS usage_count
FROM tags t
JOIN contact_tags ct ON t.id = ct.tag_id
WHERE t.is_deleted = 0
GROUP BY t.id
ORDER BY usage_count DESC
LIMIT ?;


