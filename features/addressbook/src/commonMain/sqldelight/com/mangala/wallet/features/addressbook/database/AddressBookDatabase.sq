FROM contacts
WHERE id IN (
    SELECT DISTINCT contact_id
    FROM wallet_addresses
    WHERE blockchain_type_id IN ?
)
ORDER BY name ASC
LIMIT :limit OFFSET :offset;

-- Get contact IDs with multiple filters
filterContacts:
SELECT
    c.id AS contact_id,
    c.name AS contact_name,
    wa.id AS wallet_address_id,
    wa.address AS wallet_address,
    wa.alias AS wallet_alias,
    wa.is_primary AS is_primary_address,
    wa.is_sensitive AS is_sensitive,
    bt.name AS blockchain_name,
    bt.symbol AS blockchain_symbol,
    bt.icon AS blockchain_icon,
    bt.color AS blockchain_color,
    CASE WHEN f.contact_id IS NOT NULL THEN 1 ELSE 0 END AS is_favorite,
    c.avatar,
    c.is_sensitive AS isSensitive,
    c.privacy_display_mode AS privacy_display_mode,
    -- Check if contact is in a specific tag (for address selection with pre-selected checkboxes)
    CASE
        WHEN :checkTagId IS NULL OR :checkTagId = '' THEN 0
        ELSE CASE WHEN EXISTS(
            SELECT 1 FROM contact_tags ct
            WHERE ct.contact_id = c.id AND ct.tag_id = :checkTagId
        ) THEN 1 ELSE 0 END
    END AS is_in_checked_tag
FROM contacts c
LEFT JOIN
    wallet_addresses wa ON c.id = wa.contact_id AND wa.is_primary = 1
LEFT JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
LEFT JOIN
    favorites f ON c.id = f.contact_id
WHERE
  -- Filter by favorites if requested
  (:onlyFavorites = 0 OR EXISTS (SELECT 1 FROM favorites f WHERE f.contact_id = c.id))

  -- Name/Search filter
  AND (:query = '' OR
     c.name LIKE '%' || :query || '%' OR
     wa.address LIKE '%' || :query || '%' OR
     wa.alias LIKE '%' || :query || '%' OR
     bt.symbol LIKE '%' || :query || '%')

  -- Filter by tags if requested
  AND (
    :hasTagFilters = 0 OR c.id IN (
      SELECT DISTINCT ct.contact_id
      FROM contact_tags ct
      WHERE ct.tag_id IN :tagIds
    )
  )

  -- Filter by groups if requested
  AND (
    :hasGroupFilters = 0 OR c.id IN (
      SELECT DISTINCT gw.contact_id
      FROM group_wallet gw
      WHERE gw.group_id IN :groupIds
    )
  )

  -- Filter by blockchain if requested
  AND (
    :hasBlockchainFilters = 0 OR c.id IN (
      SELECT DISTINCT wa.contact_id
      FROM wallet_addresses wa
      WHERE wa.blockchain_type_id IN :blockchainIds
    )
  )
ORDER BY
  CASE :sortOrder
    WHEN 'name_asc' THEN c.name
    WHEN 'name_desc' THEN c.name
    WHEN 'date_asc' THEN c.created_at
    WHEN 'date_desc' THEN c.created_at
  END
  || ' ' ||
  CASE :sortOrder
    WHEN 'name_asc' THEN 'ASC'
    WHEN 'name_desc' THEN 'DESC'
    WHEN 'date_asc' THEN 'ASC'
    WHEN 'date_desc' THEN 'DESC'
  END
LIMIT :limit OFFSET :offset;

-- Get contact by group id in
getContactsByGroupIdIn:
SELECT c.* FROM contacts c
INNER JOIN group_wallet gw ON c.id = gw.contact_id
WHERE gw.group_id IN ?
ORDER BY c.name ASC
LIMIT :limit OFFSET :offset;

-- Thêm mới user settings
insertUserSettings:
INSERT INTO user_settings(
  id,
  privacy_mode_enabled,
  default_privacy_display,
  biometric_auth_enabled,
  two_factor_auth_enabled,
  sync_enabled,
  default_sort_option,
  theme,
  reminder_settings,
  safe_zones,
  created_at,
  updated_at
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

-- Get recent contacts with search functionality
selectRecentContactsWithSearch:
SELECT
    th.id AS transactionId,
    COALESCE(c.id, 'unknown_' || th.to_address) AS contactId,
    COALESCE(c.name, 'Unknown') AS contactName,
    COALESCE(wa.address, CASE WHEN th.is_from_imported_wallet THEN th.to_address ELSE th.from_address END) AS walletAddress,
    COALESCE(wa.id, 'unknown') AS walletAddressId,
    COALESCE(wa.alias, '') AS walletAlias,
    COALESCE(wa.is_sensitive, 0) AS isSensitive,
    th.blockchain_type_id,
    COALESCE(bt.name, 'Unknown Network') AS blockchainName,
    COALESCE(bt.symbol, th.token_symbol) AS blockchainSymbol,
    COALESCE(bt.icon, '') AS blockchainIcon,
    th.timestamp AS lastTransactionTime,
    th.amount AS lastTransactionAmount,
    th.token_symbol AS lastTokenSymbol,
    th.status AS transactionStatus,
    th.note AS transactionNote,
    COALESCE(ct.is_sender, th.is_from_imported_wallet) AS isSender,
    CASE WHEN f.contact_id IS NOT NULL THEN 1 ELSE 0 END AS isFavorite,
    c.avatar,
    c.privacy_display_mode AS privacyDisplayMode
FROM
    transaction_history th
LEFT JOIN
    contact_transactions ct ON th.id = ct.transaction_id
LEFT JOIN
    contacts c ON ct.contact_id = c.id
LEFT JOIN
    wallet_addresses wa ON ct.wallet_address_id = wa.id
LEFT JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
LEFT JOIN
    favorites f ON c.id = f.contact_id
WHERE
    th.status IN :statuses
    AND (:searchQuery IS NULL OR :searchQuery = '' OR 
         COALESCE(c.name, th.to_address) LIKE '%' || :searchQuery || '%' OR 
         COALESCE(wa.address, th.to_address, th.from_address) LIKE '%' || :searchQuery || '%' OR
         COALESCE(bt.symbol, th.token_symbol) LIKE '%' || :searchQuery || '%')
ORDER BY
    th.timestamp DESC
LIMIT :limit OFFSET :offset;

-- Cập nhật user settings
updateUserSettings:
UPDATE user_settings
SET
  privacy_mode_enabled = ?,
  default_privacy_display = ?,
  biometric_auth_enabled = ?,
  two_factor_auth_enabled = ?,
  sync_enabled = ?,
  default_sort_option = ?,
  theme = ?,
  reminder_settings = ?,
  safe_zones = ?,
  updated_at = ?
WHERE id = ?;

-- Get favorite contacts with search functionality
getFavoritesContactsWithSearch:
SELECT DISTINCT
    c.id AS contact_id,
    c.name AS contact_name,
    wa.id AS wallet_address_id,
    wa.address AS wallet_address,
    wa.alias AS wallet_alias,
    wa.is_primary AS is_primary_address,
    wa.is_sensitive AS is_sensitive,
    bt.name AS blockchain_name,
    bt.symbol AS blockchain_symbol,
    bt.icon AS blockchain_icon,
    bt.color AS blockchain_color,
    c.avatar,
    c.is_sensitive AS isSensitive,
    c.privacy_display_mode AS privacy_display_mode
FROM
    contacts c
INNER JOIN
    favorites f ON c.id = f.contact_id
LEFT JOIN
    wallet_addresses wa ON c.id = wa.contact_id AND (wa.is_primary = 1 OR (SELECT COUNT(*) FROM wallet_addresses WHERE contact_id = c.id) = 1)
LEFT JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    (:searchQuery IS NULL OR :searchQuery = '' OR 
     c.name LIKE '%' || :searchQuery || '%' OR 
     wa.address LIKE '%' || :searchQuery || '%' OR
     wa.alias LIKE '%' || :searchQuery || '%' OR
     bt.symbol LIKE '%' || :searchQuery || '%')
ORDER BY
    f.display_order ASC,
    c.name ASC
LIMIT :limit OFFSET :offset;

filterContactsV2:
SELECT
    c.id AS contact_id,
    c.name AS contact_name,
    wa.id AS wallet_address_id,
    wa.address AS wallet_address,
    wa.alias AS wallet_alias,
    wa.is_primary AS is_primary_address,
    wa.is_sensitive AS is_sensitive,
    bt.name AS blockchain_name,
    bt.symbol AS blockchain_symbol,
    bt.icon AS blockchain_icon,
    bt.color AS blockchain_color,
    c.avatar,
    c.is_sensitive AS isSensitive,
    c.privacy_display_mode AS privacy_display_mode
FROM contacts c
LEFT JOIN
    wallet_addresses wa ON c.id = wa.contact_id
LEFT JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
  -- Filter by favorites if requested
  (:onlyFavorites = 0 OR EXISTS (SELECT 1 FROM favorites f WHERE f.contact_id = c.id))

  -- Name/Search filter
  AND (:query = '' OR c.name LIKE '%' || :query || '%')

  -- Filter by tags if requested
  AND (
    :hasTagFilters = 0 OR c.id IN (
      SELECT DISTINCT ct.contact_id
      FROM contact_tags ct
      WHERE ct.tag_id IN :tagIds
    )
  )

  -- Filter by groups if requested
  AND (
    :hasGroupFilters = 0 OR c.id IN (
      SELECT DISTINCT gw.contact_id
      FROM group_wallet gw
      WHERE gw.group_id IN :groupIds
    )
  )

  -- Filter by blockchain if requested
  AND (
    :hasBlockchainFilters = 0 OR c.id IN (
      SELECT DISTINCT wa.contact_id
      FROM wallet_addresses wa
      WHERE wa.blockchain_type_id IN :blockchainIds
    )
  )
ORDER BY
  CASE :sortOrder
    WHEN 'name_asc' THEN c.name
    WHEN 'name_desc' THEN c.name
    WHEN 'date_asc' THEN c.created_at
    WHEN 'date_desc' THEN c.created_at
  END
  || ' ' ||
  CASE :sortOrder
    WHEN 'name_asc' THEN 'ASC'
    WHEN 'name_desc' THEN 'DESC'
    WHEN 'date_asc' THEN 'ASC'
    WHEN 'date_desc' THEN 'DESC'
  END
LIMIT :limit OFFSET :offset;

insertContactTransaction:
INSERT OR REPLACE INTO contact_transactions (
    id,
    contact_id,
    transaction_id,
    wallet_address_id,
    is_sender,
    created_at
) VALUES (
    :id,
    :contactId,
    :transactionId,
    :walletAddressId,
    :isSender,
    :createdAt
);

-- insertTransactionHistory
insertTransactionHistory:
INSERT OR REPLACE INTO transaction_history (
    id,
    from_address,
    to_address,
    blockchain_type_id,
    amount,
    token_symbol,
    transaction_hash,
    status,
    timestamp,
    fee,
    note,
    is_from_imported_wallet
) VALUES (
    :id,
    :fromAddress,
    :toAddress,
    :blockchainTypeId,
    :amount,
    :tokenSymbol,
    :transactionHash,
    :status,
    :timestamp,
    :fee,
    :note,
    :isFromImportedWallet
);

getGroupById2:
SELECT
    g.id AS group_id,
    g.name AS group_name,
    g.description AS group_description,
    g.icon AS group_icon,
    g.color AS group_color,
    g.privacy_level AS privacy_level,
    g.security_level AS security_level,
    g.created_at AS created_at,
    g.updated_at AS updated_at,
    bt.id AS main_blockchain_id,
    bt.name AS main_blockchain_name,
    bt.symbol AS main_blockchain_symbol,
    bt.icon AS main_blockchain_icon,
    COUNT(DISTINCT cg.wallet_address_id) AS wallet_address_count
FROM
    groups g
LEFT JOIN
    blockchain_types bt ON g.main_blockchain_id = bt.id
LEFT JOIN
    group_wallet cg ON g.id = cg.group_id
WHERE
    g.id = ?
GROUP BY
    g.id,
    g.name,
    g.description,
    g.icon,
    g.color,
    g.privacy_level,
    g.security_level,
    g.created_at,
    g.updated_at,
    bt.name,
    bt.symbol,
    bt.icon;

updateGroupMainBlockchain:
UPDATE groups
SET main_blockchain_id = ?,
    updated_at = ?
WHERE id = ?;


getWalletAddressByGroupId:
SELECT
    c.id AS contact_id,
    c.name AS contact_name,
    c.is_sensitive AS contact_is_sensitive,
    wa.id AS wallet_address_id,
    wa.address AS wallet_address,
    wa.alias AS wallet_alias,
    wa.is_primary AS is_primary_address,
    wa.is_verified AS is_verified,
    wa.verified_date AS verified_date,
    bt.id AS blockchain_type_id,
    bt.name AS blockchain_name,
    bt.symbol AS blockchain_symbol,
    bt.icon AS blockchain_icon,
    bt.color AS blockchain_color,
    gw.created_at AS added_to_group_at,
    c.avatar,
    c.is_sensitive AS isSensitive
FROM
    group_wallet gw
JOIN
    contacts c ON gw.contact_id = c.id
JOIN
    wallet_addresses wa ON gw.wallet_address_id = wa.id
JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    gw.group_id = :groupId
ORDER BY
    c.name ASC,
    wa.is_primary DESC,
    gw.created_at DESC
LIMIT :limit OFFSET :offset;

deleteGroupWalletsByGroupId:
DELETE FROM group_wallet
WHERE group_id = ?;

getGroupWalletsByGroupId:
SELECT group_id, wallet_address_id, contact_id, created_at
FROM group_wallet
WHERE group_id = ?;

getContactsWithAddressesByGroupId:
SELECT
    c.id AS contact_id, c.name, c.notes, c.solar_birthday, c.lunar_birthday,
    c.is_sensitive, c.security_level, c.privacy_display_mode, c.auth_requirement,
    c.created_at AS contact_created_at, c.updated_at AS contact_updated_at,
    c.last_viewed_at, c.sync_status, c.encrypted_data,
    w.id AS wallet_id, w.contact_id AS wallet_contact_id, w.blockchain_type_id,
    w.address, w.alias, w.wallet_type, w.is_sensitive AS wallet_is_sensitive,
    w.is_primary, w.is_verified, w.verified_date,
    w.created_at AS wallet_created_at, w.updated_at AS wallet_updated_at
FROM group_wallet gw
JOIN contacts c ON gw.contact_id = c.id
JOIN wallet_addresses w ON gw.wallet_address_id = w.id
WHERE gw.group_id = ?;

-- Get active tags with contact count
getActiveTagsWithContactCount:
SELECT
    t.*,
    COUNT(ct.contact_id) AS contact_count
FROM tags t
LEFT JOIN (
    SELECT ct.tag_id, ct.contact_id
    FROM contact_tags ct
    INNER JOIN contacts c ON ct.contact_id = c.id
) ct ON t.id = ct.tag_id
WHERE t.is_deleted = 0
    AND (:query = '' OR t.name LIKE '%' || :query || '%')
GROUP BY t.id, t.name, t.color, t.is_deleted, t.created_at, t.updated_at
ORDER BY t.name COLLATE NOCASE ASC
LIMIT :limit OFFSET :offset;

-- Get all contact-tag pairs
getAllContactTagPairs:
SELECT contact_id, tag_id
FROM contact_tags;

-- Clean up orphaned contact-tag entries where contact no longer exists
cleanupOrphanedContactTags:
DELETE FROM contact_tags
WHERE contact_id NOT IN (SELECT id FROM contacts);

getContactsWithAddressesByBlockchainType:
SELECT
    c.id AS contact_id, c.name, c.notes, c.solar_birthday, c.lunar_birthday,
    c.is_sensitive, c.security_level, c.privacy_display_mode, c.auth_requirement,
    c.created_at AS contact_created_at, c.updated_at AS contact_updated_at,
    c.last_viewed_at, c.sync_status, c.encrypted_data,
    w.id AS wallet_id, w.contact_id AS wallet_contact_id, w.blockchain_type_id,
    w.address, w.alias, w.wallet_type, w.is_sensitive AS wallet_is_sensitive,
    w.is_primary, w.is_verified, w.verified_date,
    w.created_at AS wallet_created_at, w.updated_at AS wallet_updated_at
FROM wallet_addresses w
JOIN contacts c ON w.contact_id = c.id
WHERE w.blockchain_type_id = ?;

-- Create the address_tags table
CREATE TABLE IF NOT EXISTS address_tags (
  address_id TEXT NOT NULL,
  tag_id TEXT NOT NULL,
  created_at INTEGER NOT NULL,
  PRIMARY KEY (address_id, tag_id),
  FOREIGN KEY (address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE,
  FOREIGN KEY (tag_id) REFERENCES tags(id) ON DELETE CASCADE
);

-- Check if address-tag association exists
checkAddressTagAssociationExists:
SELECT 1
FROM address_tags
WHERE address_id = ? AND tag_id = ?
LIMIT 1;

-- Insert address tag association
insertAddressTag:
INSERT INTO address_tags (address_id, tag_id, created_at)
VALUES (?, ?, ?);

-- Remove tag from address
removeTagFromAddress:
DELETE FROM address_tags
WHERE address_id = ? AND tag_id = ?;

-- Get all address IDs with a specific tag
getAddressIdsWithTag:
SELECT address_id
FROM address_tags
WHERE tag_id = ?;

-- Get all tags for a specific address
getTagsForAddress:
SELECT t.*
FROM address_tags at
JOIN tags t ON at.tag_id = t.id
WHERE at.address_id = ?
ORDER BY t.name;

-- Count addresses for each tag (for UI display)
countAddressesByTagId:
SELECT COUNT(*)
FROM address_tags
WHERE tag_id = ?;

-- Get active tags with their address count
getActiveTagsWithAddressCount:
SELECT
    t.*,
    COUNT(at.address_id) AS address_count
FROM tags t
LEFT JOIN address_tags at ON t.id = at.tag_id
WHERE t.is_deleted = 0
GROUP BY t.id, t.name, t.color, t.text_color, t.is_deleted, t.created_at, t.updated_at
ORDER BY t.name;

-- Query to get distinct contact IDs in a group with pagination
getContactsByGroupIdPaginated:
SELECT DISTINCT
    c.id AS contact_id,
    c.name AS contact_name,
    MIN(gw.created_at) AS first_added_at
FROM
    group_wallet gw
JOIN
    contacts c ON gw.contact_id = c.id
WHERE
    gw.group_id = ?
GROUP BY
    c.id, c.name
ORDER BY
    first_added_at DESC
LIMIT ? OFFSET ?;

-- Query to get all wallet addresses for a contact in a group
getWalletAddressesForContactInGroup:
SELECT
    wa.id AS wallet_address_id,
    wa.address AS wallet_address,
    wa.alias AS wallet_alias,
    wa.is_sensitive AS wallet_is_sensitive,
    bt.name AS blockchain_name,
    bt.symbol AS blockchain_symbol,
    bt.icon AS blockchain_icon,
    bt.color AS blockchain_color,
    gw.created_at AS added_to_group_at
FROM
    wallet_addresses wa
JOIN
    group_wallet gw ON wa.id = gw.wallet_address_id
JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    gw.contact_id = ? AND gw.group_id = ?;

-- Query to count total distinct contacts in a group
countDistinctContactsInGroup:
SELECT COUNT(DISTINCT contact_id) FROM group_wallet WHERE group_id = ?;

-- Optimized query for getting GroupWallet information
getGroupWalletsByWalletIds:
SELECT
    wa.id AS wallet_id,
    wa.alias AS wallet_alias,
    wa.wallet_type AS wallet_type,
    wa.address AS wallet_address,
    c.name AS contact_name,
    bt.symbol AS blockchain_symbol,
    wa.is_sensitive AS is_sensitive,
    wa.contact_id AS contact_id
FROM
    wallet_addresses wa
JOIN
    contacts c ON wa.contact_id = c.id
JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    wa.id IN :walletIds;
    
-- Query to get wallet addresses filtered by blockchain and wallet alias for the AddWalletToGroup feature
getGroupWalletsByBlockchainAndAlias:
SELECT
    wa.id AS wallet_id,
    wa.alias AS wallet_alias,
    wa.wallet_type AS wallet_type,
    wa.address AS wallet_address,
    c.id AS contact_id,
    c.name AS contact_name,
    bt.symbol AS blockchain_symbol,
    wa.is_sensitive AS is_sensitive
FROM
    wallet_addresses wa
JOIN
    contacts c ON wa.contact_id = c.id
JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    wa.blockchain_type_id = :blockchainId
    AND (
        :searchQuery = '' 
        OR wa.alias LIKE '%' || :searchQuery || '%' 
        OR wa.address LIKE '%' || :searchQuery || '%'
        OR c.name LIKE '%' || :searchQuery || '%'
    )
ORDER BY
    c.name ASC,
    wa.is_primary DESC
LIMIT :limit OFFSET :offset;

-- Count query for pagination of wallet addresses filtered by blockchain and search
countGroupWalletsByBlockchainAndAlias:
SELECT COUNT(*)
FROM
    wallet_addresses wa
JOIN
    contacts c ON wa.contact_id = c.id
WHERE
    wa.blockchain_type_id = :blockchainId
    AND (
        :searchQuery = '' 
        OR wa.alias LIKE '%' || :searchQuery || '%' 
        OR wa.address LIKE '%' || :searchQuery || '%'
        OR c.name LIKE '%' || :searchQuery || '%'
    );

-- Query to get minimal group wallet information for display
getGroupWalletsForDisplay:
SELECT
    wa.id AS wallet_id,
    wa.alias AS wallet_alias,
    wa.wallet_type AS wallet_type,
    wa.address AS wallet_address,
    c.name AS contact_name,
    bt.symbol AS blockchain_type_symbol,
    wa.is_sensitive AS is_sensitive,
    wa.contact_id AS contact_id
FROM
    group_wallet gw
JOIN
    contacts c ON gw.contact_id = c.id
JOIN
    wallet_addresses wa ON gw.wallet_address_id = wa.id
JOIN
    blockchain_types bt ON wa.blockchain_type_id = bt.id
WHERE
    gw.group_id = :groupId
ORDER BY
    c.name ASC,
    wa.is_primary DESC
LIMIT :limit OFFSET :offset;

-- =====================================================
-- AVATAR HISTORY TABLES
-- =====================================================

-- Bảng Avatar History - Lưu lịch sử sử dụng avatar
CREATE TABLE IF NOT EXISTS avatar_history (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    avatar_source_hash TEXT NOT NULL UNIQUE,
    avatar_source_type TEXT NOT NULL, -- 'emoji', 'image', 'default', 'none'
    avatar_source_value TEXT NOT NULL, -- emoji text, image path, or resource name
    first_used_at INTEGER NOT NULL,
    last_used_at INTEGER NOT NULL,
    usage_count INTEGER DEFAULT 1,
    is_global_favorite INTEGER AS Boolean DEFAULT 0
);

-- Indexes cho performance
CREATE INDEX IF NOT EXISTS idx_avatar_history_recent ON avatar_history(last_used_at DESC);
CREATE INDEX IF NOT EXISTS idx_avatar_history_popular ON avatar_history(usage_count DESC, last_used_at DESC);
CREATE INDEX IF NOT EXISTS idx_avatar_history_hash ON avatar_history(avatar_source_hash);
CREATE INDEX IF NOT EXISTS idx_avatar_history_favorites ON avatar_history(is_global_favorite, last_used_at DESC);

-- Note: Triggers removed as SQLDelight doesn't support them
-- Cleanup and promotion logic will be handled in Kotlin code

-- =====================================================
-- AVATAR HISTORY QUERIES
-- =====================================================

-- Insert or update avatar usage
insertOrUpdateAvatarUsage:
INSERT OR REPLACE INTO avatar_history (
    avatar_source_hash,
    avatar_source_type,
    avatar_source_value,
    first_used_at,
    last_used_at,
    usage_count,
    is_global_favorite
) VALUES (
    ?,
    ?,
    ?,
    COALESCE((SELECT first_used_at FROM avatar_history WHERE avatar_source_hash = ?), ?),
    ?,
    COALESCE((SELECT usage_count FROM avatar_history WHERE avatar_source_hash = ?) + 1, 1),
    COALESCE((SELECT is_global_favorite FROM avatar_history WHERE avatar_source_hash = ?), 0)
);

-- Get recent avatars
getRecentAvatars:
SELECT * FROM avatar_history
ORDER BY last_used_at DESC
LIMIT :limit OFFSET :offset;

-- Get popular avatars
getPopularAvatars:
SELECT * FROM avatar_history
WHERE usage_count >= 3 OR is_global_favorite = 1
ORDER BY usage_count DESC, last_used_at DESC
LIMIT :limit;

-- Get global favorite avatars
getGlobalFavoriteAvatars:
SELECT * FROM avatar_history
WHERE is_global_favorite = 1
ORDER BY usage_count DESC, last_used_at DESC;

-- Search avatars by type or value
searchAvatars:
SELECT * FROM avatar_history
WHERE avatar_source_type LIKE '%' || ? || '%'
   OR avatar_source_value LIKE '%' || ? || '%'
ORDER BY usage_count DESC, last_used_at DESC
LIMIT :limit;

-- Get avatar by hash
getAvatarByHash:
SELECT * FROM avatar_history
WHERE avatar_source_hash = ?;

-- Update usage count
updateAvatarUsageCount:
UPDATE avatar_history
SET usage_count = ?, last_used_at = ?
WHERE avatar_source_hash = ?;

-- Delete old avatars (for cleanup)
deleteOldAvatars:
DELETE FROM avatar_history
WHERE last_used_at < ? AND is_global_favorite = 0;

-- Get total avatar count
getTotalAvatarCount:
SELECT COUNT(*) FROM avatar_history;

-- Promote avatar to global favorite
promoteToGlobalFavorite:
UPDATE avatar_history
SET is_global_favorite = 1
WHERE avatar_source_hash = ?;

-- Remove from global favorites
removeFromGlobalFavorites:
UPDATE avatar_history
SET is_global_favorite = 0
WHERE avatar_source_hash = ?;

-- Clear all avatar history
clearAvatarHistory:
DELETE FROM avatar_history;

-- Get oldest non-favorite avatars for cleanup
getOldestNonFavoriteAvatars:
SELECT * FROM avatar_history
WHERE is_global_favorite = 0
ORDER BY last_used_at ASC, usage_count ASC
LIMIT :limit;

-- Delete avatar by hash
deleteAvatarByHash:
DELETE FROM avatar_history
WHERE avatar_source_hash = ?;

-- =====================================================
-- CLEAR USER DATA QUERIES FOR WALLET RESET
-- =====================================================

-- Clear all contacts (CASCADE will handle related data)
clearAllContacts:
DELETE FROM contacts;

-- Clear all groups (CASCADE will handle group_wallet)
clearAllGroups:
DELETE FROM groups;

-- Clear user-created tags (preserve default tags)
clearUserTags:
DELETE FROM tags 
WHERE id NOT IN ('family', 'friends', 'work', 'exchange', 'favorite', 'investment', 'blacklist');

-- Clear transaction history
clearAllTransactionHistory:
DELETE FROM transaction_history;

-- Clear user settings (will be recreated with defaults)
clearAllUserSettings:
DELETE FROM user_settings;

-- Clear offline queue
clearAllOfflineQueue:
DELETE FROM offline_queue;

-- Clear note templates
clearAllNoteTemplates:
DELETE FROM note_templates;

-- Clear avatar history
clearAllAvatarHistory:
DELETE FROM avatar_history;

-- Clear user subscription
clearAllUserSubscription:
DELETE FROM user_subscription;

-- Clear remote keys (cache data)
clearAllRecentTxRemoteKeys:
DELETE FROM RecentTxRemoteKey;

-- =====================================================
-- ADDRESSBOOK REMOTE KEY TABLE
-- =====================================================

-- Remote key table for addressbook recent transactions pagination
CREATE TABLE IF NOT EXISTS RecentTxRemoteKey (
    query TEXT NOT NULL,
    last_requested_page INTEGER DEFAULT NULL,
    last_updated_at INTEGER NOT NULL,
    end_of_pagination_reached INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (query)
);

-- Get remote key by query and blockchain
getRecentTxRemoteKeyByQuery:
SELECT * FROM RecentTxRemoteKey
WHERE query = ?;

-- Insert or replace remote key
insertOrReplaceRecentTxRemoteKey:
INSERT OR REPLACE INTO RecentTxRemoteKey
(query, last_requested_page, last_updated_at, end_of_pagination_reached)
VALUES (?, ?, ?, ?);

-- Delete remote key by query and blockchain
deleteRecentTxRemoteKeyByQuery:
DELETE FROM RecentTxRemoteKey
WHERE query = ?;

-- Get last updated timestamp for cache validation
getRecentTxLastUpdatedTimestamp:
SELECT last_updated_at FROM RecentTxRemoteKey
WHERE query = ?;

