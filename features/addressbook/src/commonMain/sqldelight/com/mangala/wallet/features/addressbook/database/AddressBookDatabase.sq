-- Bảng lưu ghi chú cho địa chỉ ví
CREATE TABLE IF NOT EXISTS address_notes (
    id TEXT PRIMARY KEY NOT NULL,
    wallet_address_id TEXT NOT NULL,
    content TEXT NOT NULL,
    format_options TEXT,
    created_at TEXT NOT NULL,
    updated_at TEXT,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    ai_suggestion_source TEXT,
    reminder_date TEXT,
    FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS address_notes_wallet_address_id ON address_notes(wallet_address_id);
CREATE INDEX IF NOT EXISTS address_notes_content ON address_notes(content);
CREATE INDEX IF NOT EXISTS address_notes_created_at ON address_notes(created_at);
CREATE INDEX IF NOT EXISTS address_notes_is_deleted ON address_notes(is_deleted);

-- Bảng lưu lịch sử thay đổi ghi chú
CREATE TABLE IF NOT EXISTS address_notes_history (
    id TEXT PRIMARY KEY NOT NULL,
    note_id TEXT NOT NULL,
    wallet_address_id TEXT NOT NULL,
    old_content TEXT NOT NULL,
    changed_at TEXT NOT NULL,
    changed_by TEXT,
    FOREIGN KEY (note_id) REFERENCES address_notes(id) ON DELETE CASCADE,
    FOREIGN KEY (wallet_address_id) REFERENCES wallet_addresses(id) ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS address_notes_history_note_id ON address_notes_history(note_id);
CREATE INDEX IF NOT EXISTS address_notes_history_wallet_address_id ON address_notes_history(wallet_address_id);

-- Bảng lưu mẫu ghi chú
CREATE TABLE IF NOT EXISTS note_templates (
    id TEXT PRIMARY KEY NOT NULL,
    name TEXT NOT NULL,
    content TEXT NOT NULL,
    created_at TEXT NOT NULL,
    updated_at TEXT
);

CREATE INDEX IF NOT EXISTS note_templates_name ON note_templates(name);

