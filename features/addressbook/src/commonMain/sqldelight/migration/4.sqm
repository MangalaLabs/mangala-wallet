CREATE TABLE IF NOT EXISTS RecentTxRemoteKey (
    query TEXT NOT NULL,
    last_requested_page INTEGER DEFAULT NULL,
    last_updated_at INTEGER NOT NULL,
    end_of_pagination_reached INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (query)
);

-- Add column to track if transaction is from imported wallet
ALTER TABLE transaction_history ADD COLUMN is_from_imported_wallet INTEGER NOT NULL DEFAULT 0;
