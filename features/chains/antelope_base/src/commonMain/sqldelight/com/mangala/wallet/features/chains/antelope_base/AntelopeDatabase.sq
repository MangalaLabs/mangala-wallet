CREATE TABLE IF NOT EXISTS AntelopeRamMarketEntity (
    blockchain_uid TEXT PRIMARY KEY,
    supply TEXT NOT NULL,
    base_balance TEXT NOT NULL,
    base_weight TEXT NOT NULL,
    quote_balance TEXT NOT NULL,
    quote_weight TEXT NOT NULL,
    last_updated INTEGER NOT NULL
);

insertRamMarket:
INSERT OR REPLACE INTO AntelopeRamMarketEntity (blockchain_uid, supply, base_balance, base_weight, quote_balance, quote_weight, last_updated)
VALUES (?, ?, ?, ?, ?, ?, ?);

selectRamMarketRow:
SELECT * FROM AntelopeRamMarketEntity WHERE blockchain_uid = ? LIMIT 1;

CREATE TABLE IF NOT EXISTS AntelopeAccountTokenBalanceEntity (
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    key TEXT NOT NULL,
    currency TEXT NOT NULL,
    amount REAL NOT NULL,
    contract TEXT NOT NULL,
    decimals INTEGER NOT NULL,
    name TEXT NOT NULL,
    website TEXT,
    logo TEXT,
    token_created_at TEXT NOT NULL,
    exchange_name TEXT NOT NULL,
    exchange_price REAL NOT NULL,
    last_updated INTEGER NOT NULL,
    PRIMARY KEY (account_name, blockchain_uid, key),
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

insertAccountTokenBalance:
INSERT OR REPLACE INTO AntelopeAccountTokenBalanceEntity (
    account_name, blockchain_uid, key, currency, amount, contract, decimals,
    name, website, logo, token_created_at, exchange_name, exchange_price, last_updated
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectAccountTokenBalance:
SELECT * FROM AntelopeAccountTokenBalanceEntity
WHERE account_name = ? AND blockchain_uid = ?;

deleteAccountTokenBalanceByAccount:
DELETE FROM AntelopeAccountTokenBalanceEntity
WHERE account_name = ? AND blockchain_uid = ?;

