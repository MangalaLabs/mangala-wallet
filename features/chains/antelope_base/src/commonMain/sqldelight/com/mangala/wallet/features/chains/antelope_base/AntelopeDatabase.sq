insertTableRowsPowerUp:
INSERT OR REPLACE INTO AntelopeTableRowsPowerUpEntity (
    blockchain_uid, cpu_weight, net_weight, cpu_utilization, net_utilization, cpu_adjusted_utilization, net_adjusted_utilization, cpu_decay_secs, net_decay_secs, cpu_min_price, net_min_price, cpu_max_price, net_max_price, cpu_exponent, net_exponent, cpu_utilization_timestamp, net_utilization_timestamp, powerup_days, min_powerup_fee, last_updated
) VALUES ( ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectTableRowsPowerUp:
