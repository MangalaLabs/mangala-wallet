);

insertRexQueue:
INSERT OR REPLACE INTO AntelopeRexQueueEntity(id, account_name, blockchain_uid, rex_requested, proceeds, stake_change, order_time, last_updated) VALUES (?, ?, ?, ?, ?, ?, ?, ?);

selectRexQueueByAccountNameAndBlockchainUid:
SELECT * FROM AntelopeRexQueueEntity WHERE account_name = ? AND blockchain_uid = ?;

deleteRexQueueByAccountNameAndBlockchainUid:
