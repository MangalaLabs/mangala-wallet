-- TABLE ANTELOPE ACTIONS
CREATE TABLE IF NOT EXISTS AntelopeActionsEntity (
    trxId TEXT PRIMARY KEY,
    actionTrace TEXT AS List<String> NOT NULL,
    accountActionSeq TEXT AS List<Long> NOT NULL,
    blockNum TEXT AS List<Long> NOT NULL,
    accountName TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    FOREIGN KEY (accountName, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

countActions:
SELECT COUNT(*)
FROM AntelopeActionsEntity
WHERE accountName = :accountName AND blockchain_uid = :blockchain_uid;

getAntelopeActionsByAccountNamePaged:
SELECT * FROM AntelopeActionsEntity
WHERE accountName = :accountName AND blockchain_uid = :blockchain_uid
ORDER BY blockNum DESC
LIMIT :limit OFFSET :offset;

insertAntelopeAction:
INSERT OR REPLACE INTO AntelopeActionsEntity(
    trxId,
    actionTrace,
    accountActionSeq,
    blockNum,
    accountName,
    blockchain_uid
) VALUES (?, ?, ?, ?, ?, ?);


-- TABLE ANTELOPE ACTION ABI
CREATE TABLE IF NOT EXISTS AntelopeActionAbiEntity (
    action_name TEXT NOT NULL,
    account_name TEXT NOT NULL,
    field_name TEXT NOT NULL,
    field_type TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    stt INTEGER NOT NULL,
    is_variant INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (action_name, account_name, field_name)
);

insertActionsAbi:
INSERT OR REPLACE INTO AntelopeActionAbiEntity(action_name, account_name, field_name, field_type, created_at, stt, is_variant)
VALUES (?, ?, ?, ?, ?, ?, ?);


getActionAbiByAccountNameAndActionName:
SELECT * FROM AntelopeActionAbiEntity
WHERE account_name = ? AND action_name = ?
ORDER BY stt ASC;


getActionAbiByAccountName:
SELECT * FROM AntelopeActionAbiEntity
WHERE account_name = ?;

getActionAbiByActionName:
SELECT * FROM AntelopeActionAbiEntity
WHERE action_name = ?;

deleteActionAbiByAccountName:
DELETE FROM AntelopeActionAbiEntity
WHERE account_name = ?;



-- TABLE ANTELOPE ACTIONS
CREATE TABLE IF NOT EXISTS AntelopeActionEntity (
    actionName TEXT NOT NULL,
    accountName TEXT NOT NULL,
    lastTimeUpdatedCode INTEGER NOT NULL,
    PRIMARY KEY (actionName, accountName)
);


insertActions:
INSERT OR REPLACE INTO AntelopeActionEntity(actionName, accountName, lastTimeUpdatedCode)
VALUES (?, ?, ?);


deleteActionsByAccountName:
DELETE FROM AntelopeActionEntity
WHERE accountName = ?;


getActionsByAccountName:
SELECT * FROM AntelopeActionEntity
WHERE accountName = ?;

getActionTraceFromAntelopeActionByTrxId:
SELECT actionTrace FROM AntelopeActionsEntity WHERE trxId = ?;

-- TABLE ANTELOPE ACTION TRACE
CREATE TABLE IF NOT EXISTS AntelopeActionTraceEntity (
    trx_id TEXT NOT NULL,
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    timestamp TEXT NOT NULL,
    block_num INTEGER NOT NULL,
    block_id TEXT NOT NULL,
    act TEXT NOT NULL,
    receipts TEXT NOT NULL,
    global_sequence INTEGER NOT NULL,
    producer TEXT NOT NULL,
    action_ordinal INTEGER NOT NULL,
    creator_action_ordinal INTEGER NOT NULL,
    cpu_usage_us INTEGER NOT NULL,
    net_usage_words INTEGER NOT NULL,
    signatures TEXT NOT NULL,
    account_action_seq INTEGER NOT NULL,
    action_trace TEXT NOT NULL,
    block_time TEXT NOT NULL,
    global_action_sequence INTEGER NOT NULL,
    irreversible INTEGER NOT NULL,
    transaction_type TEXT NOT NULL,
    PRIMARY KEY (trx_id, account_name, blockchain_uid, global_sequence),
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

insertAntelopeActionTrace:
INSERT OR REPLACE INTO AntelopeActionTraceEntity(
    trx_id,
    account_name,
    blockchain_uid,
    timestamp,
    block_num,
    block_id,
    act,
    receipts,
    global_sequence,
    producer,
    action_ordinal,
    creator_action_ordinal,
    cpu_usage_us,
    net_usage_words,
    signatures,
    account_action_seq,
    action_trace,
    block_time,
    global_action_sequence,
    irreversible,
    transaction_type
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

selectAntelopeActionTraceByType:
SELECT * FROM AntelopeActionTraceEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND transaction_type = :transactionType;

-- TABLE ANTELOPE ACTION TRACE CACHE METADATA
CREATE TABLE IF NOT EXISTS AntelopeActionTraceCacheMetadataEntity(
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    transaction_type TEXT NOT NULL,
    last_updated INTEGER NOT NULL,
    lookup_before_timestamp TEXT NOT NULL,
    past_data_load_finished INTEGER NOT NULL,
    PRIMARY KEY (account_name, blockchain_uid, transaction_type),
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

insertAntelopeActionTraceCacheMetadata:
INSERT OR REPLACE INTO AntelopeActionTraceCacheMetadataEntity(
    account_name,
    blockchain_uid,
    transaction_type,
    last_updated,
    lookup_before_timestamp,
    past_data_load_finished
) VALUES (?, ?, ?, ?, ?, ?);

selectAntelopeActionTraceCacheMetadata:
SELECT * FROM AntelopeActionTraceCacheMetadataEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND transaction_type = :transactionType;

-- TABLE ANTELOPE RAM OHLC
CREATE TABLE IF NOT EXISTS AntelopeRamOhlcEntity (
    blockchain_uid TEXT NOT NULL,
    sampling_interval TEXT NOT NULL,
    timestamp INTEGER NOT NULL,
    open REAL NOT NULL,
    high REAL NOT NULL,
    low REAL NOT NULL,
    close REAL NOT NULL,
    usd REAL NOT NULL,
    volume INTEGER NOT NULL,
    last_updated INTEGER NOT NULL,
    PRIMARY KEY (blockchain_uid, sampling_interval, timestamp)
);

insertRamOhlc:
INSERT OR REPLACE INTO AntelopeRamOhlcEntity (blockchain_uid, sampling_interval, timestamp, open, high, low, close, usd, volume, last_updated)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteRamOhlcByBlockchainUidAndSamplingInterval:
DELETE FROM AntelopeRamOhlcEntity WHERE blockchain_uid = ? AND sampling_interval = ?;

selectRamOhlcByBlockchainUidAndSamplingInterval:
SELECT * FROM AntelopeRamOhlcEntity WHERE blockchain_uid = ? AND sampling_interval = ?;

-- TABLE ANTELOPE PROPOSAL
CREATE TABLE IF NOT EXISTS AntelopeProposalEntity (
    proposal_name TEXT NOT NULL,
    proposer TEXT NOT NULL,
    requested_approvals TEXT AS List<String> DEFAULT NULL,
    blockchain_uid TEXT NOT NULL,
    account_name TEXT NOT NULL,
    created_at INTEGER NOT NULL,
    expires_at INTEGER NOT NULL,
    actionsName TEXT AS List<String> NOT NULL,
    is_draft INTEGER NOT NULL,
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE,
    PRIMARY KEY (proposal_name, blockchain_uid, account_name)
);

countProposals:
SELECT COUNT(*)
FROM AntelopeProposalEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND proposer = :accountName;

getAntelopeProposalsByAccountNamePaged:
SELECT * FROM AntelopeProposalEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND proposer = :accountName
LIMIT :limit OFFSET :offset;

upsertProposal {
    UPDATE AntelopeProposalEntity
    SET proposer = :proposer,
        blockchain_uid = :blockchain_uid,
        created_at = :created_at,
        expires_at = :expires_at,
        actionsName = :actionsName,
        account_name = :accountName,
        is_draft = :isDraft
    WHERE proposal_name = :proposal_name AND blockchain_uid = :blockchain_uid AND created_at < :created_at;

    INSERT OR IGNORE INTO AntelopeProposalEntity(proposal_name, proposer, blockchain_uid, account_name, created_at, expires_at, actionsName, is_draft)
    VALUES (:proposal_name, :proposer, :blockchain_uid, :accountName, :created_at, :expires_at, :actionsName, :isDraft);
}

insertOrReplaceProposal:
INSERT OR REPLACE INTO AntelopeProposalEntity(
    proposal_name, proposer, blockchain_uid, account_name, created_at, expires_at, actionsName, is_draft, requested_approvals
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteProposal:
DELETE FROM AntelopeProposalEntity WHERE proposal_name = ? AND blockchain_uid = ? AND account_name = ?;

invalidateCachedProposals:
DELETE FROM AntelopeProposalEntity
WHERE is_draft = 0 AND account_name = :accountName
AND blockchain_uid = :blockchainUid AND proposer = :accountName;

-- Approval
countApprovals:
SELECT COUNT(*)
FROM AntelopeProposalEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND proposer != :accountName;

getAntelopeApprovalsByAccountNamePaged:
SELECT * FROM AntelopeProposalEntity
WHERE account_name = :accountName AND blockchain_uid = :blockchain_uid AND proposer != :accountName
LIMIT :limit OFFSET :offset;

invalidateCachedApprovals:
DELETE FROM AntelopeProposalEntity
WHERE is_draft = 0 AND account_name = :accountName
AND blockchain_uid = :blockchainUid AND proposer != :accountName;

CREATE TABLE IF NOT EXISTS AntelopeRemoteKey (
    query TEXT NOT NULL,
    last_requested_key INTEGER DEFAULT NULL,
    blockchain_uid TEXT NOT NULL,
    target_cache_entity TEXT AS AntelopeRemoteKeyTargetEntity NOT NULL,
    last_updated_at INTEGER NOT NULL,
    end_of_pagination_reached INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (query, blockchain_uid, target_cache_entity)
);

insertAntelopeRemoteKey:
INSERT OR REPLACE INTO AntelopeRemoteKey(query, last_requested_key, blockchain_uid, target_cache_entity, last_updated_at, end_of_pagination_reached)
VALUES (?, ?, ?, ?, ?, ?);

getAntelopeRemoteKey:
SELECT * FROM AntelopeRemoteKey
WHERE query = :query AND blockchain_uid = :blockchain_uid AND target_cache_entity = :target_cache_entity;

deleteAntelopeRemoteKey:
DELETE FROM AntelopeRemoteKey
WHERE query = :query AND blockchain_uid = :blockchain_uid AND target_cache_entity = :target_cache_entity;

getLastUpdateTimeStamp:
SELECT last_updated_at FROM AntelopeRemoteKey
WHERE query = :query AND blockchain_uid = :blockchain_uid AND target_cache_entity = :target_cache_entity
ORDER BY last_updated_at ASC
LIMIT 1;

CREATE TABLE IF NOT EXISTS AntelopeMsigProposalDraftEntity(
    id INTEGER PRIMARY KEY AUTOINCREMENT, -- use this as primary key to allow changing the proposal name on save
    proposal_name TEXT NOT NULL,
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    proposer_permission_name TEXT NOT NULL,
    actions_detail_json TEXT NOT NULL,
    approvers_detail_json TEXT NOT NULL,
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE,
    FOREIGN KEY (proposal_name, blockchain_uid, account_name) REFERENCES AntelopeProposalEntity(proposal_name, blockchain_uid, account_name) ON DELETE CASCADE
);

insertMsigProposalDraft:
INSERT OR REPLACE INTO AntelopeMsigProposalDraftEntity(
    id,
    proposal_name,
    account_name,
    blockchain_uid,
    proposer_permission_name,
    actions_detail_json,
    approvers_detail_json
) VALUES (?, ?, ?, ?, ?, ?, ?);

selectMsigProposalDraftByAccountName:
SELECT
    d.id AS id,
    p.proposal_name AS proposal_name,
    p.account_name AS account_name,
    p.proposer AS proposer,
    p.requested_approvals AS requested_approvals,
    p.blockchain_uid AS blockchain_uid,
    p.created_at AS created_at,
    p.expires_at AS expires_at,
    p.actionsName AS actions_name,
    d.proposer_permission_name AS draft_proposer_permission_name,
    d.actions_detail_json AS draft_actions_detail_json,
    d.approvers_detail_json AS draft_approvers_detail_json
FROM
    AntelopeProposalEntity p
INNER JOIN
    AntelopeMsigProposalDraftEntity d
ON
    p.account_name = d.account_name
    AND p.proposal_name = d.proposal_name
    AND p.blockchain_uid = d.blockchain_uid
WHERE d.proposal_name = ? AND d.account_name = ? AND d.blockchain_uid = ?;

getDraftProposalExists:
SELECT COUNT(*) FROM AntelopeMsigProposalDraftEntity WHERE proposal_name = ? AND account_name = ? AND blockchain_uid = ?;

deleteProposalDraft:
DELETE FROM AntelopeMsigProposalDraftEntity WHERE proposal_name = ? AND account_name = ? AND blockchain_uid = ?;

-- Clear all Antelope cache and global data (non-CASCADE tables)
clearAllAntelopeRexPools:
DELETE FROM AntelopeRexPoolEntity;

clearAllAntelopeRamMarkets:
DELETE FROM AntelopeRamMarketEntity;

clearAllAntelopeTableRowsPowerUp:
DELETE FROM AntelopeTableRowsPowerUpEntity;

clearAllAntelopeActionAbi:
DELETE FROM AntelopeActionAbiEntity;

clearAllAntelopeActions:
DELETE FROM AntelopeActionEntity;

