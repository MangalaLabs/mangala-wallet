import app.cash.paging.LoadType;
import com.mangala.wallet.features.chains.antelope_base.domain.model.cache.AntelopeRemoteKeyTargetEntity;
import kotlin.Long;
import kotlin.String;
import kotlin.collections.List;

CREATE TABLE IF NOT EXISTS AntelopeAccountEntity (
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    is_active INTEGER NOT NULL,
--     Account create flags
    create_account_state TEXT NOT NULL,
    is_temp INTEGER NOT NULL,
    purchase_token TEXT,
    purchase_id TEXT,
--     Balances cache
    core_liquid_balance TEXT,
    cpu_limit_max INTEGER,
    cpu_limit_available INTEGER,
    cpu_limit_current_used INTEGER,
    net_limit_max INTEGER,
    net_limit_available INTEGER,
    net_limit_current_used INTEGER,
    ram_quota INTEGER,
    ram_usage INTEGER,
    rex_balance TEXT,
    self_delegated_bandwidth_cpu_weight TEXT,
    self_delegated_bandwidth_net_weight TEXT,
    total_resources_net_weight TEXT,
    total_resources_cpu_weight TEXT,
    last_updated INTEGER NOT NULL,
    is_notification_registered INTEGER NOT NULL,
    is_deleted INTEGER NOT NULL DEFAULT 0,
    PRIMARY KEY (account_name, blockchain_uid)
);

selectAllPermanentAccounts:
SELECT *
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND is_temp = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

selectAllPermanentAccountsBasicInfo:
SELECT account_name, blockchain_uid
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND is_temp = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

selectAllAccounts:
SELECT *
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

selectAllAccountsBasicInfo:
SELECT account_name, blockchain_uid
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

countAllAccounts:
SELECT COUNT(account_name)
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

countAllPermanentAccounts:
SELECT COUNT(account_name)
FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND is_deleted = 0
  AND is_temp = 0
  AND (create_account_state != :exclude_create_account_state OR :exclude_create_account_state IS NULL);

selectAccountByName:
SELECT * FROM AntelopeAccountEntity WHERE is_deleted = 0 AND account_name = ? AND blockchain_uid = ?;

insertAccount:
INSERT OR IGNORE INTO AntelopeAccountEntity(account_name, blockchain_uid, is_active, is_temp, create_account_state, purchase_token, last_updated, is_notification_registered) VALUES (?, ?, ?, ?, ?, ?, ?, ?);

insertOrReplaceAccount:
INSERT OR REPLACE INTO AntelopeAccountEntity(account_name, blockchain_uid, is_active, is_temp, create_account_state, purchase_token, last_updated, is_notification_registered, is_deleted) VALUES (?, ?, ?, ?, ?, ?, ?, ?, 0);

resetDeletedFlag:
UPDATE AntelopeAccountEntity SET is_deleted = 0 WHERE account_name = ? AND blockchain_uid = ?;

deleteAccount:
DELETE FROM AntelopeAccountEntity WHERE account_name = ? AND blockchain_uid = ?;

deleteAccounts:
DELETE FROM AntelopeAccountEntity
WHERE blockchain_uid = ?
  AND create_account_state = ?
  AND last_updated <= ?;

updateAccountBalance:
UPDATE AntelopeAccountEntity SET
core_liquid_balance = ?,
cpu_limit_max = ?,
cpu_limit_available = ?,
cpu_limit_current_used = ?,
net_limit_max = ?,
net_limit_available = ?,
net_limit_current_used = ?,
ram_quota = ?,
ram_usage = ?,
rex_balance = ?,
self_delegated_bandwidth_cpu_weight = ?,
self_delegated_bandwidth_net_weight = ?,
total_resources_net_weight = ?,
total_resources_cpu_weight = ?,
last_updated = ?
WHERE account_name = ? AND blockchain_uid = ?;

updateAccountStatus:
UPDATE AntelopeAccountEntity SET is_temp = ?, create_account_state = ? WHERE account_name = ? AND blockchain_uid = ?;

updateAccountStatusAndPurchaseToken:
UPDATE AntelopeAccountEntity SET is_temp = ?, create_account_state = ?, purchase_token = ?, purchase_id = ? WHERE account_name = ? AND blockchain_uid = ?;

updateNotificationRegistered:
UPDATE AntelopeAccountEntity SET is_notification_registered = ? WHERE account_name = ? AND blockchain_uid = ?;

selectAccountsFailedToRegisterNotification:
SELECT * FROM AntelopeAccountEntity WHERE is_deleted = 0 AND is_notification_registered = 0 AND is_temp = 0 AND blockchain_uid = ?;

softDeleteAccount:
UPDATE AntelopeAccountEntity SET is_deleted = 1 WHERE account_name = ? AND blockchain_uid = ?;

selectSoftDeletedAccounts:
SELECT * FROM AntelopeAccountEntity WHERE is_deleted = 1 AND blockchain_uid = ?;

CREATE TABLE IF NOT EXISTS AntelopeAccountPermissionEntity (
    account_name TEXT NOT NULL,
    permission_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    parent TEXT NOT NULL,
    PRIMARY KEY (account_name, permission_name, blockchain_uid),
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

selectAccountPermissionByAccountAndPermissionName:
SELECT * FROM AntelopeAccountPermissionEntity WHERE account_name = ? AND permission_name = ? AND blockchain_uid = ?;

selectAccountPermissionsByAccountName:
SELECT * FROM AntelopeAccountPermissionEntity WHERE account_name = ? AND blockchain_uid = ?;

insertAccountPermission:
INSERT OR REPLACE INTO AntelopeAccountPermissionEntity(account_name, permission_name, blockchain_uid, parent) VALUES (?, ?, ?, ?);

CREATE TABLE IF NOT EXISTS AntelopeAccountKeyEntity (
    id TEXT PRIMARY KEY,
    public_key TEXT NOT NULL,
    weight INTEGER NOT NULL,
    account_name TEXT NOT NULL,
    permission_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    is_synced INTEGER NOT NULL,
    FOREIGN KEY (account_name, permission_name, blockchain_uid) REFERENCES AntelopeAccountPermissionEntity(account_name, permission_name, blockchain_uid) ON DELETE CASCADE
);

insertAccountKey:
INSERT OR REPLACE INTO AntelopeAccountKeyEntity(id, public_key, weight, account_name, permission_name, blockchain_uid, is_synced) VALUES (?, ?, ?, ?, ?, ?, ?);

selectAccountKeyByAccountNameAndPermissionName:
SELECT * FROM AntelopeAccountKeyEntity WHERE account_name = ? AND permission_name = ? AND blockchain_uid = ?;

selectSyncedAccountKeysByAccountNameAndPermissionName:
SELECT * FROM AntelopeAccountKeyEntity WHERE account_name = ? AND permission_name = ? AND is_synced = 1 AND blockchain_uid = ?;

CREATE TABLE IF NOT EXISTS AntelopeRexPoolEntity(
    blockchain_uid TEXT PRIMARY KEY,
    total_lent TEXT NOT NULL,
    total_unlent TEXT NOT NULL,
    total_rent TEXT NOT NULL,
    total_lendable TEXT NOT NULL,
    total_rex TEXT NOT NULL,
    namebid_proceeds TEXT NOT NULL,
    loan_num INTEGER NOT NULL,
    last_updated INTEGER NOT NULL
);

insertRexPool:
INSERT OR REPLACE INTO AntelopeRexPoolEntity(blockchain_uid, total_lent, total_unlent, total_rent, total_lendable, total_rex, namebid_proceeds, loan_num, last_updated) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

selectRexPool:
SELECT * FROM AntelopeRexPoolEntity WHERE blockchain_uid = ?;

CREATE TABLE IF NOT EXISTS AntelopeRexFundEntity(
    account_name TEXT PRIMARY KEY,
    blockchain_uid TEXT NOT NULL,
    balance TEXT NOT NULL,
    last_updated INTEGER NOT NULL,
    FOREIGN KEY (account_name, blockchain_uid) REFERENCES AntelopeAccountEntity(account_name, blockchain_uid) ON DELETE CASCADE
);

insertRexFund:
INSERT OR REPLACE INTO AntelopeRexFundEntity(account_name, blockchain_uid, balance, last_updated) VALUES (?, ?, ?, ?);

selectRexFund:
SELECT * FROM AntelopeRexFundEntity WHERE account_name = ? AND blockchain_uid = ?;

CREATE TABLE IF NOT EXISTS AntelopeRexQueueEntity(
    id TEXT PRIMARY KEY,
    account_name TEXT NOT NULL,
    blockchain_uid TEXT NOT NULL,
    rex_requested TEXT NOT NULL,
    proceeds TEXT NOT NULL,
