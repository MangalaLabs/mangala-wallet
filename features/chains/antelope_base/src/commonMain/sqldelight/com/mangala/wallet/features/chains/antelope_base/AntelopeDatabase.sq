);

insertAnchorLinkSession:
INSERT OR REPLACE INTO AntelopeAnchorLinkSessionEntity(account_name, blockchain_uid, session_name, session_url, session_receive_public_key, session_request_public_key) VALUES (?, ?, ?, ?, ?, ?);

selectAnchorLinkSession:
SELECT * FROM AntelopeAnchorLinkSessionEntity WHERE account_name = ? AND blockchain_uid = ?;

selectAnchorLinkSessionByUrl:
SELECT * FROM AntelopeAnchorLinkSessionEntity WHERE session_url = ?;

selectAnchorLinkSessionsByBlockchainUid:
